\n\ndef save_checkpoint(name, obj):\n    path = os.path.join(CHECKPOINT, f\"{name}.pkl\")\n    with open(path, 'wb') as f: pickle.dump(obj, f)\n    print(f\"  вң… Saved: {name}.pkl\")\n\ndef load_checkpoint(name):\n    path = os.path.join(CHECKPOINT, f\"{name}.pkl\")\n    if os.path.exists(path):\n        with open(path, 'rb') as f: obj = pickle.load(f)\n        print(f\"  вҸ© Resuming: {name}.pkl\")\n        return obj, True\n    return None, False\n\ndef threshold_accuracy(actual, predicted, threshold=5.0):\n    pct_error = np.abs((actual - predicted) / actual) * 100\n    return (pct_error <= threshold).mean() * 100\n\ndef rmse(actual, predicted):\n    return np.sqrt(np.mean((actual - predicted) ** 2))\n\ndef mape(actual, predicted):\n    return np.mean(np.abs((actual - predicted) / actual)) * 100\n\nprint(\"\\n\" + \"=\"*60)\nprint(\"  STEP 6 FIXED: Proper Ensemble\")\nprint(\"=\"*60)\n\n# ============================================================\n# Load all data\n# ============================================================\nml_data, _    = load_checkpoint(\"step4_all_ml\")\ndl_data, _    = load_checkpoint(\"step5v2_all_dl\")\nstep3, _      = load_checkpoint(\"step3_data\")\n\nml_preds      = ml_data['ml_predictions']\ny_ml_actual   = ml_data['y_test_actual']\nml_test_df    = ml_data['test_df']\n\ndl_preds_raw  = dl_data['dl_predictions']\ny_dl_actual   = dl_data['y_seq_test_actual']\ndl_meta       = dl_data['test_seq_meta']\nstock_scalers = dl_data['stock_scalers']\n\nX_train       = step3['X_train']\nX_test        = step3['X_test']\ny_train       = step3['y_train']\nscaler_y      = step3['scaler_y']\ntest_df       = step3['test_df']\nfeature_cols  = step3['feature_cols']\n\nstocks = sorted(test_df['Stock_Symbol'].unique())\n\n# ============================================================\n# FIX: Align DL predictions to ML ordering\n# ML test_df is sorted by Date (chronological)\n# DL meta is sorted per-stock вҶ’ reindex by Date+Stock\n# ============================================================\nprint(\"\\nрҹ“Ң FIX: Aligning DL predictions to ML ordering...\")\n\nresult, found = load_checkpoint(\"step6_fixed_dl_preds\")\nif found:\n    dl_preds_aligned = result\nelse:\n    # Build alignment index\n    # test_df has Date + Stock_Symbol\n    # dl_meta has date + stock columns\n    test_df_reset = test_df.reset_index(drop=True)\n    test_df_reset['__idx__'] = test_df_reset.index\n\n    dl_meta_reset = dl_meta.reset_index(drop=True)\n    dl_meta_reset['__dl_idx__'] = dl_meta_reset.index\n\n    # Merge on Date + Stock\n    test_df_reset['Date_str']   = pd.to_datetime(\n        test_df_reset['Date']).dt.strftime('%Y-%m-%d')\n    dl_meta_reset['Date_str']   = pd.to_datetime(\n        dl_meta_reset['date']).dt.strftime('%Y-%m-%d')\n\n    merged = test_df_reset[['Date_str','Stock_Symbol','__idx__']].merge(\n        dl_meta_reset[['Date_str','stock','__dl_idx__']],\n        left_on  = ['Date_str','Stock_Symbol'],\n        right_on = ['Date_str','stock'],\n        how='left'\n    )\n\n    # Check alignment quality\n    matched   = merged['__dl_idx__'].notna().sum()\n    unmatched = merged['__dl_idx__'].isna().sum()\n    print(f\"   Matched rows   : {matched}\")\n    print(f\"   Unmatched rows : {unmatched}\")\n\n    dl_preds_aligned = {}\n    for dl_name, dl_arr in dl_preds_raw.items():\n        aligned = np.zeros(len(test_df_reset))\n        for _, row in merged.iterrows():\n            ml_i = int(row['__idx__'])\n            if pd.notna(row['__dl_idx__']):\n                dl_i = int(row['__dl_idx__'])\n                aligned[ml_i] = dl_arr[dl_i]\n            else:\n                # Fill unmatched with ML GradientBoosting prediction\n                aligned[ml_i] = ml_preds['GradientBoosting'][ml_i]\n        dl_preds_aligned[dl_name] = aligned\n\n    save_checkpoint(\"step6_fixed_dl_preds\", dl_preds_aligned)\n\n# Use ML actual prices as ground truth (properly aligned)\ny_actual  = y_ml_actual\nstock_col = test_df['Stock_Symbol'].values\n\nprint(f\"\\n   Verifying DL alignment (Acc@5% should be ~50-61%):\")\nfor name, preds in dl_preds_aligned.items():\n    acc = threshold_accuracy(y_actual, preds, 5)\n    r   = rmse(y_actual, preds)\n    print(f\"   {name:<10} RMSE:{r:>8.2f}  Acc@5%:{acc:>7.2f}%\")\n\n# ============================================================\n# Build full prediction matrix (all models properly aligned)\n# ============================================================\nprint(\"\\nрҹ“Ң Building Aligned Prediction Matrix...\")\n\nall_preds   = {}\nmodel_names = []\n\nfor name, preds in ml_preds.items():\n    all_preds[name] = preds\n    model_names.append(name)\n\nfor name, preds in dl_preds_aligned.items():\n    all_preds[name] = preds\n    model_names.append(name)\n\nP = np.column_stack([all_preds[n] for n in model_names])\nprint(f\"   Matrix shape: {P.shape}\")\n\n# ============================================================\n# ENSEMBLE 1: ML-only Ensembles\n# (DL models are weaker вҖ” ML dominates)\n# ============================================================\nprint(\"\\nрҹ“Ң Building Ensembles...\")\n\nensemble_results = {}\n\n# Simple average of all ML\nP_ml     = np.column_stack([ml_preds[n] for n in ml_preds])\navg_ml   = P_ml.mean(axis=1)\nensemble_results['SimpleAvg_ML'] = avg_ml\n\n# Weighted by Acc@5% вҖ” ML only\nml_accs  = {n: threshold_accuracy(y_actual, ml_preds[n], 5)\n            for n in ml_preds}\nml_total = sum(ml_accs.values())\nwt_ml    = {n: ml_accs[n]/ml_total for n in ml_preds}\nwt_ml_pred = sum(wt_ml[n] * ml_preds[n] for n in ml_preds)\nensemble_results['WeightedAvg_ML'] = wt_ml_pred\n\n# Top-3 ML simple average\ntop3_ml  = sorted(ml_preds, key=lambda n: ml_accs[n], reverse=True)[:3]\nP_top3   = np.column_stack([ml_preds[n] for n in top3_ml])\nensemble_results['Top3_ML'] = P_top3.mean(axis=1)\n\n# Best 2 ML\ntop2_ml  = top3_ml[:2]\nP_top2   = np.column_stack([ml_preds[n] for n in top2_ml])\nensemble_results['Top2_ML'] = P_top2.mean(axis=1)\n\n# ML + aligned DL (all 9 models)\navg_all  = P.mean(axis=1)\nensemble_results['SimpleAvg_All9'] = avg_all\n\n# Weighted by Acc@5% вҖ” all 9 models\nall_accs = {n: threshold_accuracy(y_actual, all_preds[n], 5)\n            for n in model_names}\nall_total = sum(all_accs.values())\nwt_all    = {n: all_accs[n]/all_total for n in model_names}\nwt_all_pred = sum(wt_all[n] * all_preds[n] for n in model_names)\nensemble_results['WeightedAvg_All9'] = wt_all_pred\n\n# Optimized weights (scipy) on ML only вҖ” no leakage risk\nprint(\"\\n   Running weight optimizer (ML only)...\")\nopt_result, opt_found = load_checkpoint(\"step6v2_opt_ml\")\nif opt_found:\n    opt_w_ml = opt_result\nelse:\n    P_ml_arr = np.column_stack([ml_preds[n] for n in ml_preds])\n    def neg_acc_ml(w):\n        w = np.abs(w) / (np.abs(w).sum() + 1e-9)\n        return -threshold_accuracy(y_actual, P_ml_arr @ w, 5)\n    best_w, best_acc = None, 999\n    for seed in range(50):\n        np.random.seed(seed)\n        w0  = np.random.dirichlet(np.ones(5))\n        res = minimize(neg_acc_ml, w0,\n                       method='SLSQP',\n                       bounds=[(0,1)]*5,\n                       constraints={'type':'eq',\n                                    'fun': lambda w: np.sum(w)-1})\n        if res.fun < best_acc:\n            best_acc = res.fun\n            best_w   = res.x\n    opt_w_ml = np.abs(best_w) / np.abs(best_w).sum()\n    save_checkpoint(\"step6v2_opt_ml\", opt_w_ml)\n\nopt_ml_pred = np.column_stack([ml_preds[n] for n in ml_preds]) @ opt_w_ml\nensemble_results['OptWeights_ML'] = opt_ml_pred\n\nprint(f\"   Optimized ML weights:\")\nfor n, w in zip(ml_preds.keys(), opt_w_ml):\n    print(f\"      {n:<22} вҶ’ {w*100:>5.1f}%\")\n\n# Stacking meta-learner (trained on ML train preds)\nprint(\"\\n   Building Stacking Ensemble...\")\nstack_result, stack_found = load_checkpoint(\"step6v2_stacking\")\nif stack_found:\n    stacking_pred = stack_result\nelse:\n    ml_models_ck = {\n        n: load_checkpoint(f\"step4_model_{n}\")[0]['model']\n        for n in ml_preds.keys()\n    }\n    y_train_actual = scaler_y.inverse_transform(\n                         y_train.reshape(-1,1)).ravel()\n    S_train = np.column_stack([\n        scaler_y.inverse_transform(\n            m.predict(X_train).reshape(-1,1)).ravel()\n        for m in ml_models_ck.values()\n    ])\n    S_test  = np.column_stack([ml_preds[n] for n in ml_preds])\n\n    meta = Ridge(alpha=0.5)\n    meta.fit(S_train, y_train_actual)\n    stacking_pred = meta.predict(S_test)\n    save_checkpoint(\"step6v2_stacking\", stacking_pred)\n\nensemble_results['Stacking_Ridge'] = stacking_pred\n\n# ML + best DL blend\nbest_dl_name = max(dl_preds_aligned,\n    key=lambda n: threshold_accuracy(y_actual, dl_preds_aligned[n], 5))\nbest_dl_acc  = threshold_accuracy(y_actual,\n                   dl_preds_aligned[best_dl_name], 5)\nprint(f\"\\n   Best aligned DL: {best_dl_name} вҶ’ {best_dl_acc:.2f}%\")\n\n# 80% best ML + 20% best DL\nbest_ml_name = max(ml_preds,\n    key=lambda n: threshold_accuracy(y_actual, ml_preds[n], 5))\nblend_80_20  = 0.80*ml_preds[best_ml_name] + 0.20*dl_preds_aligned[best_dl_name]\nblend_70_30  = 0.70*ml_preds[best_ml_name] + 0.30*dl_preds_aligned[best_dl_name]\nblend_90_10  = 0.90*ml_preds[best_ml_name] + 0.10*dl_preds_aligned[best_dl_name]\nensemble_results['80%GB+20%DL'] = blend_80_20\nensemble_results['70%GB+30%DL'] = blend_70_30\nensemble_results['90%GB+10%DL'] = blend_90_10\n\n# Save all\nsave_checkpoint(\"step6v2_all\", {\n    'ensemble_results' : ensemble_results,\n    'all_preds'        : all_preds,\n    'dl_preds_aligned' : dl_preds_aligned,\n    'y_actual'         : y_actual,\n    'test_df'          : test_df\n})\n\n# ============================================================\n# RESULTS\n# ============================================================\nprint(\"\\n\" + \"=\"*60)\nprint(\"  рҹ“Ҡ FIXED ENSEMBLE RESULTS\")\nprint(\"=\"*60)\n\nprint(f\"\\n{'Model/Ensemble':<26} {'RMSE'