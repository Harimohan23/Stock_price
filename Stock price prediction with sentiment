=====================================\n# STEP 4: Machine Learning Models\n# RF, XGBoost, LightGBM, SVR, Ridge вҖ” with full checkpointing\n# ============================================================\n\nimport os, pickle, warnings, time\nimport numpy as np\nimport pandas as pd\nfrom sklearn.ensemble import RandomForestRegressor, GradientBoostingRegressor\nfrom sklearn.linear_model  import Ridge\nfrom sklearn.svm           import SVR\nfrom xgboost               import XGBRegressor\nfrom lightgbm              import LGBMRegressor\n\nwarnings.filterwarnings('ignore')\n\nCHECKPOINT = \"/kaggle/working/checkpoints\"\nos.makedirs(CHECKPOINT, exist_ok=True)\n\ndef save_checkpoint(name, obj):\n    path = os.path.join(CHECKPOINT, f\"{name}.pkl\")\n    with open(path, 'wb') as f: pickle.dump(obj, f)\n    print(f\"  вң… Saved: {name}.pkl\")\n\ndef load_checkpoint(name):\n    path = os.path.join(CHECKPOINT, f\"{name}.pkl\")\n    if os.path.exists(path):\n        with open(path, 'rb') as f: obj = pickle.load(f)\n        print(f\"  вҸ© Resuming: {name}.pkl\")\n        return obj, True\n    return None, False\n\n# в”Җв”Җ Accuracy metric (same as paper) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n# If predicted is within threshold% of actual вҶ’ correct\ndef threshold_accuracy(actual, predicted, threshold=5.0):\n    pct_error = np.abs((actual - predicted) / actual) * 100\n    return (pct_error <= threshold).mean() * 100\n\ndef rmse(actual, predicted):\n    return np.sqrt(np.mean((actual - predicted) ** 2))\n\ndef mae(actual, predicted):\n    return np.mean(np.abs(actual - predicted))\n\ndef mape(actual, predicted):\n    return np.mean(np.abs((actual - predicted) / actual)) * 100\n\nprint(\"\\n\" + \"=\"*60)\nprint(\"  STEP 4: Machine Learning Models\")\nprint(\"=\"*60)\n\n# в”Җв”Җ Load Step 3 data в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nstep3, _ = load_checkpoint(\"step3_data\")\nX_train      = step3['X_train']\nX_test       = step3['X_test']\ny_train      = step3['y_train']\ny_test       = step3['y_test']\nscaler_y     = step3['scaler_y']\ntest_df      = step3['test_df']\nfeature_cols = step3['feature_cols']\n\n# Inverse transform targets back to actual prices\ny_train_actual = scaler_y.inverse_transform(y_train.reshape(-1,1)).ravel()\ny_test_actual  = scaler_y.inverse_transform(y_test.reshape(-1,1)).ravel()\n\n# ============================================================\n# Model Configs\n# ============================================================\nmodel_configs = {\n\n    'RandomForest': RandomForestRegressor(\n        n_estimators   = 500,\n        max_depth      = 15,\n        min_samples_split = 5,\n        min_samples_leaf  = 2,\n        max_features   = 'sqrt',\n        n_jobs         = -1,\n        random_state   = 42\n    ),\n\n    'XGBoost': XGBRegressor(\n        n_estimators   = 500,\n        max_depth      = 6,\n        learning_rate  = 0.05,\n        subsample      = 0.8,\n        colsample_bytree = 0.8,\n        min_child_weight = 3,\n        gamma          = 0.1,\n        reg_alpha      = 0.1,\n        reg_lambda     = 1.0,\n        n_jobs         = -1,\n        random_state   = 42,\n        verbosity      = 0\n    ),\n\n    'LightGBM': LGBMRegressor(\n        n_estimators   = 500,\n        max_depth      = 8,\n        learning_rate  = 0.05,\n        subsample      = 0.8,\n        colsample_bytree = 0.8,\n        min_child_samples = 20,\n        reg_alpha      = 0.1,\n        reg_lambda     = 1.0,\n        n_jobs         = -1,\n        random_state   = 42,\n        verbose        = -1\n    ),\n\n    'GradientBoosting': GradientBoostingRegressor(\n        n_estimators   = 300,\n        max_depth      = 5,\n        learning_rate  = 0.05,\n        subsample      = 0.8,\n        min_samples_split = 5,\n        min_samples_leaf  = 2,\n        random_state   = 42\n    ),\n\n    'Ridge': Ridge(\n        alpha          = 1.0\n    ),\n}\n\n# ============================================================\n# Train Each Model (with individual checkpoints)\n# ============================================================\nml_predictions = {}   # model_name вҶ’ predicted actual prices\nml_models      = {}   # model_name вҶ’ trained model object\n\nfor model_name, model in model_configs.items():\n\n    ck_name = f\"step4_model_{model_name}\"\n    result, found = load_checkpoint(ck_name)\n\n    if found:\n        ml_models[model_name]      = result['model']\n        ml_predictions[model_name] = result['preds']\n        print(f\"     Model loaded  : {model_name}\")\n    else:\n        print(f\"\\n  рҹ”„ Training {model_name}...\")\n        t0 = time.time()\n\n        model.fit(X_train, y_train)\n\n        # Predict on test set\n        preds_scaled = model.predict(X_test)\n        preds_actual = scaler_y.inverse_transform(\n                           preds_scaled.reshape(-1,1)).ravel()\n\n        ml_models[model_name]      = model\n        ml_predictions[model_name] = preds_actual\n\n        elapsed = time.time() - t0\n        print(f\"     Done in {elapsed:.1f}s\")\n\n        save_checkpoint(ck_name, {'model': model, 'preds': preds_actual})\n\n# ============================================================\n# Save All ML Predictions Together\n# ============================================================\nresult, found = load_checkpoint(\"step4_all_ml\")\nif not found:\n    save_checkpoint(\"step4_all_ml\", {\n        'ml_predictions': ml_predictions,\n        'y_test_actual' : y_test_actual,\n        'test_df'       : test_df\n    })\n\nprint(\"\\n\" + \"=\"*60)\nprint(\"  вң… ALL ML MODELS TRAINED\")\nprint(\"=\"*60)\n\n# ============================================================\n# в”Җв”Җ OPTIONAL ACCURACY BLOCK в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n# Set SHOW_ACCURACY = True to see results\n# Set SHOW_ACCURACY = False to skip (default)\n# ============================================================\nSHOW_ACCURACY = True   # вҶҗ change to False to skip\n\nif SHOW_ACCURACY:\n\n    thresholds = [3, 5, 10]   # paper uses ~3-5% implicitly\n\n    print(\"\\n\" + \"=\"*60)\n    print(\"  рҹ“Ҡ ML MODEL ACCURACY RESULTS\")\n    print(\"=\"*60)\n\n    # в”Җв”Җ Overall Accuracy Table в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    print(f\"\\n{'Model':<20} {'RMSE':>8} {'MAE':>8} {'MAPE%':>8} \"\n          f\"{'Acc@3%':>8} {'Acc@5%':>8} {'Acc@10%':>9}\")\n    print(\"-\"*75)\n\n    overall_results = {}\n    for model_name, preds in ml_predictions.items():\n        r  = rmse(y_test_actual, preds)\n        m  = mae(y_test_actual, preds)\n        mp = mape(y_test_actual, preds)\n        a3 = threshold_accuracy(y_test_actual, preds, 3)\n        a5 = threshold_accuracy(y_test_actual, preds, 5)\n        a10= threshold_accuracy(y_test_actual, preds, 10)\n        overall_results[model_name] = {\n            'RMSE':r,'MAE':m,'MAPE':mp,'Acc@3':a3,'Acc@5':a5,'Acc@10':a10\n        }\n        print(f\"{model_name:<20} {r:>8.2f} {m:>8.2f} {mp:>8.2f}% \"\n              f\"{a3:>7.2f}% {a5:>7.2f}% {a10:>8.2f}%\")\n\n    # в”Җв”Җ Best Model в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    best_model = max(overall_results,\n                     key=lambda x: overall_results[x]['Acc@5'])\n    print(f\"\\n  рҹҸҶ Best ML Model (Acc@5%) : {best_model} \"\n          f\"вҶ’ {overall_results[best_model]['Acc@5']:.2f}%\")\n\n    # в”Җв”Җ Per-Company Accuracy Table в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    print(\"\\n\" + \"=\"*60)\n    print(\"  рҹ“Ҳ PER-COMPANY ACCURACY (Acc@5%) вҖ” All ML Models\")\n    print(\"=\"*60)\n\n    stocks = sorted(test_df['Stock_Symbol'].unique())\n\n    # Header\n    header = f\"{'Company':<18}\"\n    for mn in ml_predictions.keys():\n        short = mn[:10]\n        header += f\" {short:>11}\"\n    print(header)\n    print(\"-\" * (18 + 12 * len(ml_predictions)))\n\n    per_company_results = {}\n    for stock in stocks:\n        mask = test_df['Stock_Symbol'].values == stock\n        actual_stock = y_test_actual[mask]\n        row = f\"{stock:<18}\"\n        per_company_results[stock] = {}\n        for model_name, preds in ml_predictions.items():\n            preds_stock = preds[mask]\n            acc = threshold_accuracy(actual_stock, preds_stock, 5)\n            per_company_results[stock][model_name] = acc\n            row += f\" {acc:>10.2f}%\"\n        print(row)\n\n    # Average row\n    print(\"-\" * (18 + 12 * len(ml_predictions)))\n    avg_row = f\"{'AVERAGE':<18}\"\n    for model_name in ml_predictions.keys():\n        avg = np.mean([per_company_results[s][model_name] for s in stocks])\n        avg_row += f\" {avg:>10.2f}%\"\n    print(avg_row)\n\n    # в”Җв”Җ Per-Company Best Model в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    print(\"\\n  рҹҸҶ Best ML Model per Company (Acc@5%):\")\n    for stock in stocks:\n        best = max(per_company_results[stock],\n                   key=per_company_results[stock].get)\n        best_acc = per_company_results[stock][best]\n        print(f\"     {stock:<20} вҶ’ {best:<20} {best_acc:.2f}%\")\n\n    # в”Җв”Җ Paper Comparison в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    print(\"\\n\" + \"=\"*60)\n    print(\"  рҹ“° COMPARISON WITH BASE PAPER\")\n    print(\"=\"*60)\n    paper_ensemble_avg = 91.89\n    best_ml_acc = overall_results[best_model]['Acc@5']\n    print(f\"  Paper Ensemble Accuracy  : {paper_ensemble_avg:.2f}%\")\n    print(f\"  Our Best ML Accuracy     : {best_ml_acc:.2f}%\")\n    gap = paper_ensemble_avg - best_ml_acc\n    if gap <= 0:\n        print(f\"  вң… We BEAT the paper by   : {abs(gap):.2f}%\")\n    else:\n        print(f\"  рҹ“ү Gap to close in DL     : {gap:.2f}%  (expected вҖ” ML alone)\")\n\nprint(\"\\nвң… STEP 4 COMPLETE вҖ” Move to Step 5: Deep Learning!\")\nprint(\"=\"*60)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-24T08:43:28.755231Z","iopub.execute_input":"2026-04-24T08:43:28.755565Z","iopub.status.idle":"2026-04-24T08:45:05.598903Z","shell.execute_reply.started":"2026-04-24T08:43:28.755542Z","shell.execute_reply":"2026-04-24T08:45:05.597982Z"}},"outputs":[{"name":"stdout","text":"\n============================================================\n  STEP 4: Machine Learning Models\n============================================================\n  вҸ© Resuming: step3_data.pkl\n\n  рҹ”„ Training RandomForest...\n     Done in 10.2s\n  вң… Saved: step4_model_RandomForest.pkl\n\n  рҹ”„ Training XGBoost...\n     Done in 0.8s\n  вң… Saved: step4_model_XGBoost.pkl\n\n  рҹ”„ Training LightGBM...\n     Done in 1.6s\n  вң… Saved: step4_model_LightGBM.pkl\n\n  рҹ”„ Training GradientBoosting...\n     Done in 77.9s\n  вң… Saved: step4_model_GradientBoosting.pkl\n\n  рҹ”„ Training Ridge...\n     Done in 0.0s\n  вң… Saved: step4_model_Ridge.pkl\n  вң… Saved: step4_all_ml.pkl\n\n============================================================\n  вң… ALL ML MODELS TRAINED\n============================================================\n\n============================================================\n  рҹ“Ҡ ML MODEL ACCURACY RESULTS\n============================================================\n\nModel                    RMSE      MAE    MAPE%   Acc@3%   Acc@5%   Acc@10%\n---------------------------------------------------------------------------\nRandomForest           157.42    62.73     2.32%   77.21%   88.21%    95.09%\nXGBoost                175.65    75.04     6.91%   69.35%   78.99%    88.33%\nLightGBM               126.25    44.92     1.75%   83.48%   93.61%    98.53%\nGradientBoosting       113.13    41.41     1.6