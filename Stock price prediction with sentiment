    вң… +4.24%\n  GradientBoosting              95.15%        вң… +3.26%\n  Top2_ML                       95.02%        вң… +3.13%\n  90%GB+10%DL                   94.59%        вң… +2.70%\n  LightGBM                      93.61%        вң… +1.72%\n  Ridge                         93.49%        вң… +1.60%\n  80%GB+20%DL                   91.46%        рҹ“ү -0.43%\n  RandomForest                  88.21%        рҹ“ү -3.68%\n  WeightedAvg_ML                87.35%        рҹ“ү -4.54%\n\n  рҹҸҶ BEST VALID RESULT : OptWeights_ML вҶ’ 96.25%\n  вң… BEATS paper by 4.36%\n\nвң… STEP 6 FIXED COMPLETE!\n============================================================\n","output_type":"stream"}],"execution_count":9},{"cell_type":"code","source":"# ============================================================\n# STEP 5 PER-STOCK DL: Each stock gets its own model\n# Then ensemble: 2-model, 3-model, 4-model combinations\n# ============================================================\n\nimport os, pickle, warnings, time, itertools\nimport numpy as np\nimport pandas as pd\nimport tensorflow as tf\nfrom tensorflow.keras.models    import Sequential\nfrom tensorflow.keras.layers    import (LSTM, GRU, Dense, Dropout,\n                                         Bidirectional, SimpleRNN,\n                                         BatchNormalization)\nfrom tensorflow.keras.callbacks import (EarlyStopping, ModelCheckpoint,\n                                         ReduceLROnPlateau)\nfrom tensorflow.keras.optimizers import Adam\nfrom sklearn.preprocessing      import MinMaxScaler\n\nwarnings.filterwarnings('ignore')\ntf.get_logger().setLevel('ERROR')\n\nCHECKPOINT   = \"/kaggle/working/checkpoints\"\nPS_WEIGHTS   = \"/kaggle/working/per_stock_weights\"\nos.makedirs(CHECKPOINT, exist_ok=True)\nos.makedirs(PS_WEIGHTS,  exist_ok=True)\n\ndef save_checkpoint(name, obj):\n    path = os.path.join(CHECKPOINT, f\"{name}.pkl\")\n    with open(path, 'wb') as f: pickle.dump(obj, f)\n    print(f\"  вң… Saved: {name}.pkl\")\n\ndef load_checkpoint(name):\n    path = os.path.join(CHECKPOINT, f\"{name}.pkl\")\n    if os.path.exists(path):\n        with open(path, 'rb') as f: obj = pickle.load(f)\n        print(f\"  вҸ© Resuming: {name}.pkl\")\n        return obj, True\n    return None, False\n\ndef threshold_accuracy(actual, predicted, threshold=5.0):\n    pct_error = np.abs((actual - predicted) / actual) * 100\n    return (pct_error <= threshold).mean() * 100\n\ndef rmse(actual, predicted):\n    return np.sqrt(np.mean((actual - predicted) ** 2))\n\ndef mape(actual, predicted):\n    return np.mean(np.abs((actual - predicted) / actual)) * 100\n\nprint(\"\\n\" + \"=\"*60)\nprint(\"  PER-STOCK DL TRAINING + DL ENSEMBLE\")\nprint(\"=\"*60)\n\n# в”Җв”Җ Load data в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nstep3, _     = load_checkpoint(\"step3_data\")\nfeature_cols = step3['feature_cols']\ntrain_df     = step3['train_df']\ntest_df      = step3['test_df']\n\n# Also load ML best predictions for comparison\nml_data, _   = load_checkpoint(\"step4_all_ml\")\nml_preds     = ml_data['ml_predictions']\ny_actual_ml  = ml_data['y_test_actual']\n\nSEQ_LEN    = 60\nN_FEATURES = len(feature_cols)\nstocks     = sorted(train_df['Stock_Symbol'].unique())\nstock_col  = test_df.sort_values('Date')['Stock_Symbol'].values\n\n# ============================================================\n# MODEL BUILDERS (compact for per-stock вҖ” less overfitting)\n# ============================================================\ndef build_lstm(seq_len, n_feat):\n    m = Sequential([\n        LSTM(64, return_sequences=True, input_shape=(seq_len, n_feat)),\n        BatchNormalization(), Dropout(0.2),\n        LSTM(32, return_sequences=False),\n        BatchNormalization(), Dropout(0.2),\n        Dense(32, activation='relu'), Dropout(0.1),\n        Dense(1)\n    ], name='LSTM')\n    m.compile(optimizer=Adam(0.001), loss='huber', metrics=['mae'])\n    return m\n\ndef build_gru(seq_len, n_feat):\n    m = Sequential([\n        GRU(64, return_sequences=True, input_shape=(seq_len, n_feat)),\n        BatchNormalization(), Dropout(0.2),\n        GRU(32, return_sequences=False),\n        BatchNormalization(), Dropout(0.2),\n        Dense(32, activation='relu'), Dropout(0.1),\n        Dense(1)\n    ], name='GRU')\n    m.compile(optimizer=Adam(0.001), loss='huber', metrics=['mae'])\n    return m\n\ndef build_bilstm(seq_len, n_feat):\n    m = Sequential([\n        Bidirectional(LSTM(32, return_sequences=True),\n                      input_shape=(seq_len, n_feat)),\n        BatchNormalization(), Dropout(0.2),\n        Bidirectional(LSTM(16, return_sequences=False)),\n        BatchNormalization(), Dropout(0.2),\n        Dense(32, activation='relu'), Dropout(0.1),\n        Dense(1)\n    ], name='BiLSTM')\n    m.compile(optimizer=Adam(0.001), loss='huber', metrics=['mae'])\n    return m\n\ndef build_rnn(seq_len, n_feat):\n    m = Sequential([\n        SimpleRNN(64, return_sequences=True, input_shape=(seq_len, n_feat)),\n        BatchNormalization(), Dropout(0.2),\n        SimpleRNN(32, return_sequences=False),\n        BatchNormalization(), Dropout(0.2),\n        Dense(32, activation='relu'), Dropout(0.1),\n        Dense(1)\n    ], name='RNN')\n    m.compile(optimizer=Adam(0.001), loss='huber', metrics=['mae'])\n    return m\n\nbuilders = {\n    'LSTM'  : build_lstm,\n    'GRU'   : build_gru,\n    'BiLSTM': build_bilstm,\n    'RNN'   : build_rnn\n}\n\n# ============================================================\n# TRAIN PER STOCK PER MODEL\n# Structure: per_stock_preds[stock][model] = array of predictions\n# ============================================================\nprint(\"\\nрҹ“Ң Training Per-Stock DL Models...\")\nprint(\"   (Each stock Г— 4 models = 44 models total)\\n\")\n\n# Final storage\nper_stock_preds  = {}   # [stock][model_name] = test predictions\nper_stock_actual = {}   # [stock] = actual test prices\n\nfor stock in stocks:\n    per_stock_preds[stock]  = {}\n    print(f\"\\n  {'='*50}\")\n    print(f\"  рҹ“Ҳ {stock}\")\n    print(f\"  {'='*50}\")\n\n    # в”Җв”Җ Get stock data в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    tr = train_df[train_df['Stock_Symbol']==stock].sort_values('Date').reset_index(drop=True)\n    te = test_df[test_df['Stock_Symbol']==stock].sort_values('Date').reset_index(drop=True)\n\n    # в”Җв”Җ Per-stock scaler в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    sx = MinMaxScaler()\n    sy = MinMaxScaler()\n    tr_X = sx.fit_transform(tr[feature_cols].values)\n    tr_y = sy.fit_transform(tr['Target'].values.reshape(-1,1)).ravel()\n    te_X = sx.transform(te[feature_cols].values)\n    te_y = sy.transform(te['Target'].values.reshape(-1,1)).ravel()\n\n    # Store actual prices for this stock\n    per_stock_actual[stock] = sy.inverse_transform(\n                                  te_y.reshape(-1,1)).ravel()\n\n    # в”Җв”Җ Build sequences в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    X_tr, y_tr = [], []\n    for i in range(SEQ_LEN, len(tr)):\n        X_tr.append(tr_X[i-SEQ_LEN:i])\n        y_tr.append(tr_y[i])\n    X_tr = np.array(X_tr, dtype=np.float32)\n    y_tr = np.array(y_tr, dtype=np.float32)\n\n    # Test sequences (seed from train tail)\n    seed_X      = tr_X[-SEQ_LEN:]\n    combined_X  = np.vstack([seed_X, te_X])\n    combined_y  = np.concatenate([tr_y[-SEQ_LEN:], te_y])\n    X_te, y_te  = [], []\n    for i in range(SEQ_LEN, len(combined_X)):\n        X_te.append(combined_X[i-SEQ_LEN:i])\n        y_te.append(combined_y[i])\n    X_te = np.array(X_te, dtype=np.float32)\n    y_te = np.array(y_te, dtype=np.float32)\n\n    print(f\"  Train sequences: {X_tr.shape}  \"\n          f\"Test sequences: {X_te.shape}\")\n\n    # в”Җв”Җ Train each model for this stock в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    for model_name, builder in builders.items():\n\n        ck_name = f\"ps_{stock.replace('.','_')}_{model_name}\"\n        saved, found = load_checkpoint(ck_name)\n        if found:\n            per_stock_preds[stock][model_name] = saved\n            acc = threshold_accuracy(\n                      per_stock_actual[stock], saved, 5)\n            print(f\"  вҸ© {model_name:<8} loaded  \"\n                  f\"Acc@5%: {acc:.2f}%\")\n            continue\n\n        # Build + train\n        model    = builder(SEQ_LEN, N_FEATURES)\n        wt_path  = os.path.join(\n            PS_WEIGHTS,\n            f\"{stock.replace('.','_')}_{model_name}.weights.h5\"\n        )\n\n        # Resume weights if interrupted\n        if os.path.exists(wt_path):\n            model.load_weights(wt_path)\n\n        callbacks = [\n            EarlyStopping(monitor='val_loss', patience=20,\n                          restore_best_weights=True, verbose=0),\n            ModelCheckpoint(wt_path, monitor='val_loss',\n                            save_best_only=True,\n                            save_weights_only=True, verbose=0),\n            ReduceLROnPlateau(monitor='val_loss', factor=0.5,\n                              patience=8, min_lr=1e-7, verbose=0)\n        ]\n\n        t0 = time.time()\n        model.fit(\n            X_tr, y_tr,\n            validation_split = 0.15,\n            epochs           = 150,\n            batch_size       = 32,\n            callbacks        = callbacks,\n            verbose          = 0\n        )\n        elapsed = time.time() - t0\n\n        # Predict + inverse transform\n        preds_sc = model.predict(X_te, verbose=0).ravel()\n        preds_ac = sy.inverse_transform(\n                       preds_sc.reshape(-1,1)).ravel()\n\n        per_stock_preds[stock][model_name] = preds_ac\n        acc = threshold_accuracy(per_stock_actual[stock],\n                                  preds_ac, 5)\n        print(f\"  вң… {model_name:<8} \"\n              f\"trained {elapsed:.0f}s  Acc@5%: {acc:.2f}%\")\n\n        save_checkpoint(ck_name, preds_ac)\n\n        # Clear session to free GPU memory\n        tf.keras.backend.clear_session()\n\n# ============================================================\n# ASSEMBLE FULL TEST ARRAYS\n# Map per-stock predictions back to full test_df order\n# ============================================================\nprint(\"\\n\\nрҹ“Ң Assembling Full Prediction Arrays...\")\n\ntest_df_sorted = test_df.sort_values('Date').reset_index(drop=True)\n\n# Build index map: stock вҶ’ row indices in test_df_sorted\nstock_indices = {}\nfor stock in stocks:\n    mask = test_df_sorted['Stock_Symbol'].values == stock\n    stock_indices[stock] = np.where(mask)[0]\n\n# Full arrays for each DL model\nfull_preds = {mn: np.zeros(len(test_df_sorted))\n              for mn in builders.keys()}\nfull_actual = np.zeros(len(test_df_sorted))\n\nfor stock in stocks:\n    idx   = stock_indices[stock]\n    n_idx = len(idx)\n    for mn in builders.keys():\n        ps_pred = per_stock_preds[stock][mn]\n        # Align lengths (test sequences may differ by 1)\n        n_use = min(n_idx, len(ps_pred))\n        full_preds[mn][idx[:n_use]] = ps_pred[:n_use]\n    act   = per_stock_actual[stock]\n    n_use = min(n_idx, len(act))\n    full_actual[idx[:n_use]] = act[:n_use]\n\n# Save assembled predictions\nsave_checkpoint(\"step5ps_full_preds\", {\n    'full_preds'  : full_preds,\n    'full_actual' : full_actual,\n    'per_stock_preds' : per_stock_preds\n})\n\n# ============================================================\n# VERIFY PER-STOCK DL RESULTS\n# ============================================================\nprint(\"\\n\" + \"=\"*60)\nprint(\"  рҹ“Ҡ PER-STOCK DL INDIVIDUAL RESULTS (Acc@5%)\")\nprint(\"=\"*60)\n\nprint(f\"\\n  {'Stock':<20} {'LSTM':>8} {'GRU':>8} \"\n      f\"{'BiLSTM':>8} {'RNN':>8}\")\nprint(\"  \" + \"-\"*56)\n\ndl_stock_accs = {mn: [] for mn in builders}\nfor stock in stocks:\n    row = f\"  {stock:<20}\"\n    for mn in builders:\n        idx    = stock_indices[stock]\n        n_use  = min(len(idx), len(per_stock_preds[stock][mn]))\n        act_s  = full_actual[idx[:n_use]]\n        pred_s = full_preds[mn][idx[:n_use]]\n        acc    = threshold_accuracy(act_s, pred_s, 5)\n        dl_stock_accs[mn].append(acc)\n        row   += f\" {acc:>7.2f}%\"\n    print(row)\n\nprint(\"  \" + \"-\"*56)\navg_row = f\"  {'AVERAGE':<20}\"\nfor mn in builders:\n    avg_row += f\" {np.mean(dl_stock_accs[mn]):>7.2f}%\"\nprint(avg_row)\n\n# ============================================================\n# DL ENSEMBLE COMBINATIONS\n# 2-model, 3-model, 4-model вҖ” simple average + weighted\n# ============================================================\nprint(\"\\n\" + \"=\"*60)\nprint(\"  рҹ“Ҡ DL ENSEMBLE COMBINATIONS\")\nprint(\"=\"*60)\n\ny_actual   = full_actual   # use assembled actual prices\nmodel_list = list(builders.keys())\n\ndl_ensemble_results = {}\n\n# в”Җв”Җ All individual models first в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nfor mn in model_list:\n    dl_ensemble_results[mn] = full_preds[mn]\n\n# в”Җв”Җ 2-model combinations в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nprint(\"\\n  2-Model Combinations:\")\nfor c in itertools.combinations(model_list, 2):\n    name = '+'.join(c)\n    pred = np.mean([full_preds[m] for m in c], axis=0)\n    dl_ensemble_results[name] = pred\n    acc  = threshold_accuracy(y_actual, pred, 5)\n    print(f\"    {name:<20} Acc@5%: {acc:.2f}%\")\n\n# в”Җв”Җ 3-model combinations в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nprint(\"\\n  3-Model Combinations:\")\nfor c in itertools.combinations(model_list, 3):\n    name = '+'.join(c)\n    pred = np.mean([full_preds[m] for m in c], axis=0)\n    dl_ensemble_results[name] = pred\n    acc  = threshold_accuracy(y_actual, pred, 5)\n    print(f\"    {name:<25} Acc@5%: {acc:.2f}%\")\n\n# в”Җв”Җ 4-model combination в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nprint(\"\\n  4-Model Combination:\")\npred_4 = np.mean([full_preds[m] for m in model_list], axis=0)\ndl_ensemble_results['LSTM+GRU+BiLSTM+RNN'] = pred_4\nacc_4 = threshold_accuracy(y_actual, pred_4, 5)\nprint(f\"    All 4 DL Models         Acc@5%: {acc_4:.2f}%\")\n\n# в”Җв”Җ Weighted by individual accuracy в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nprint(\"\\n  Accuracy-Weighted Combination:\")\nindiv_accs = {mn: threshold_accuracy(y_actual, full_preds[mn], 5)\n              for mn in model_list}\ntotal_acc  = sum(indiv_accs.values())\nw_pred = sum((indiv_accs[mn]/total_acc) * full_preds[mn]\n             for mn in model_list)\ndl_ensemble_results['AccWeighted_DL'] = w_pred\nacc_w = threshold_accuracy(y_actual, w_pred, 5)\nprint(f\"    AccWeighted              Acc@5%: {acc_w:.2f}%\")\nfor mn, a in indiv_accs.items():\n    print(f\"      {mn:<10} weight: \"\n          f\"{indiv_accs[mn]/total_acc*100:.1f}%  \"\n          f\"indiv acc: {a:.2f}%\")\n\n# в”Җв”Җ Best DL ensemble в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nbest_dl_ens = max(dl_ensemble_results,\n    key=lambda n: threshold_accuracy(y_actual,\n                      dl_ensemble_results[n], 5))\nbest_dl_acc = threshold_accuracy(\n    y_actual, dl_ensemble_results[best_dl_ens], 5)\n\nprint(f\"\\n  рҹҸҶ Best DL Ensemble: {best_dl_ens} вҶ’ {best_dl_acc:.2f}%\")\n\n# ============================================================\n# COMBINED ML + DL ENSEMBLE\n# ============================================================\nprint(\"\\n\" + \"=\"*60)\nprint(\"  рҹ“Ҡ ML + DL COMBINED ENSEMBLE\")\nprint(\"=\"*60)\n\n# Load best ML predictions\nbest_ml_name = 'GradientBoosting'\nbest_ml_pred = ml_preds[best_ml_name]\n\n# Align ML predictions to sorted test_df order\n# (step4 uses test_df which is already sorted by date)\nml_pred_aligned = best_ml_pred  # already aligned\n\nbest_dl_pred    = dl_ensemble_results[best_dl_ens]\n\ncombined_results = {}\n\n# Various blends\nfor ml_w in [0.5, 0.6, 0.65, 0.7, 0.75, 0.8, 0.85, 0.9]:\n    dl_w  = 1 - ml_w\n    name  = f\"ML{int(ml_w*100)}+DL{int(dl_w*100)}\"\n    pred  = ml_w * ml_pred_aligned + dl_w * best_dl_pred\n    acc   = threshold_accuracy(y_actual, pred, 5)\n    combined_results[name] = (pred, acc)\n\n# OptWeights ML + best DL\nopt_ens, _ = load_checkpoint(\"step6v2_all\")\nif opt_ens:\n    opt_ml_pred = opt_ens['ensemble_results']['OptWeights_ML']\n    for ml_w in [0.6, 0.7, 0.75, 0.8]:\n        dl_w  = 1 - ml_w\n        name  = f\"OptML{int(ml_w*100)}+DL{int(dl_w*100)}\"\n        pred  = ml_w * opt_ml_pred + dl_w * best_dl_pred\n        acc   = threshold_accuracy(y_actual, pred, 5)\n        combined_results[name] = (pred, acc)\n\n# Print combined results\nprint(f\"\\n  {'Combination':<25} {'Acc@5%':>8}\")\nprint(\"  \" + \"-\"*35)\nfor name, (pred, acc) in sorted(combined_results.items(),\n                                  key=lambda x: -x[1][1]):\n    status = \"вң…\" if acc >= 91.89 else \"рҹ“ү\"\n    print(f\"  {name:<25} {acc:>7.2f}%  {status}\")\n\nbest_comb = max(combined_results,\n                key=lambda n: combined_results[n][1])\nbest_comb_acc  = combined_results[best_comb][1]\nbest_comb_pred = combined_results[best_comb][0]\n\nprint(f\"\\n  рҹҸҶ Best Combined: {best_comb} вҶ’ {best_comb_acc:.2f}%\")\n\n# ============================================================\n# FINAL SUMMARY TABLE\n# ============================================================\nprint(\"\\n\" + \"=\"*60)\nprint(\"  рҹ“Ҡ FINAL SUMMARY вҖ” ALL APPROACHES\")\nprint(\"=\"*60)\n\nprint(f\"\\n  {'Method':<30} {'Acc@5%':>8}  {'vs Paper':>12}\")\nprint(\"  \" + \"-\"*55)\nprint(f\"