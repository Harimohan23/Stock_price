rue\n    return None, False\n\ndef threshold_accuracy(actual, predicted, threshold=5.0):\n    pct_error = np.abs((actual - predicted) / actual) * 100\n    return (pct_error <= threshold).mean() * 100\n\ndef rmse(actual, predicted):\n    return np.sqrt(np.mean((actual - predicted) ** 2))\n\ndef mae(actual, predicted):\n    return np.mean(np.abs(actual - predicted))\n\ndef mape(actual, predicted):\n    return np.mean(np.abs((actual - predicted) / actual)) * 100\n\nprint(\"\\n\" + \"=\"*60)\nprint(\"  STEP 6: Ensemble Modeling\")\nprint(\"=\"*60)\n\n# ============================================================\n# 6A: Load All Predictions\n# ============================================================\nprint(\"\\nрҹ“Ң 6A: Loading All Model Predictions...\")\n\n# в”Җв”Җ ML predictions (on test_df вҖ” 1628 rows) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nml_data, _   = load_checkpoint(\"step4_all_ml\")\nml_preds     = ml_data['ml_predictions']   # dict: name вҶ’ array\ny_ml_actual  = ml_data['y_test_actual']    # actual prices\nml_test_df   = ml_data['test_df']\n\n# в”Җв”Җ DL predictions (on test_seq вҖ” 1628 rows) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\ndl_data, _   = load_checkpoint(\"step5v2_all_dl\")\ndl_preds     = dl_data['dl_predictions']\ny_dl_actual  = dl_data['y_seq_test_actual']\ndl_meta      = dl_data['test_seq_meta']\nstock_scalers= dl_data['stock_scalers']\n\n# в”Җв”Җ Step 3 for stacking features в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nstep3, _     = load_checkpoint(\"step3_data\")\nX_train      = step3['X_train']\nX_test       = step3['X_test']\ny_train      = step3['y_train']\nscaler_y     = step3['scaler_y']\ntrain_df     = step3['train_df']\ntest_df      = step3['test_df']\nfeature_cols = step3['feature_cols']\n\n# Verify alignment\nassert len(y_ml_actual) == len(y_dl_actual), \"Size mismatch ML vs DL!\"\ny_actual = y_ml_actual   # same actual prices, use ML version\nstocks   = sorted(test_df['Stock_Symbol'].unique())\n\nprint(f\"   ML models loaded  : {list(ml_preds.keys())}\")\nprint(f\"   DL models loaded  : {list(dl_preds.keys())}\")\nprint(f\"   Test samples      : {len(y_actual)}\")\n\n# ============================================================\n# 6B: Build Prediction Matrix\n# Rows = test samples, Cols = each model's prediction\n# ============================================================\nprint(\"\\nрҹ“Ң 6B: Building Prediction Matrix...\")\n\nmodel_names = list(ml_preds.keys()) + list(dl_preds.keys())\nall_preds   = {}\n\nfor name, preds in ml_preds.items():\n    all_preds[name] = preds\n\nfor name, preds in dl_preds.items():\n    all_preds[name] = preds\n\n# Stack into matrix\nP = np.column_stack([all_preds[n] for n in model_names])\nprint(f\"   Prediction matrix shape : {P.shape}\")\nprint(f\"   Models: {model_names}\")\n\n# ============================================================\n# 6C: Individual Model Baseline\n# ============================================================\nprint(\"\\nрҹ“Ң 6C: Individual Model Baselines (Acc@5%):\")\nprint(f\"   {'Model':<22} {'Acc@3%':>8} {'Acc@5%':>8} {'Acc@10%':>9}\")\nprint(\"   \" + \"-\"*50)\nfor name in model_names:\n    a3  = threshold_accuracy(y_actual, all_preds[name], 3)\n    a5  = threshold_accuracy(y_actual, all_preds[name], 5)\n    a10 = threshold_accuracy(y_actual, all_preds[name], 10)\n    print(f\"   {name:<22} {a3:>7.2f}% {a5:>7.2f}% {a10:>8.2f}%\")\n\n# ============================================================\n# 6D: Simple Ensemble Methods\n# ============================================================\nprint(\"\\nрҹ“Ң 6D: Simple Ensemble Methods...\")\n\nensemble_results = {}\n\n# в”Җв”Җ D1: Simple Average (all models) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\navg_all = P.mean(axis=1)\nensemble_results['SimpleAvg_All'] = avg_all\n\n# в”Җв”Җ D2: Simple Average (ML only) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nP_ml = np.column_stack([ml_preds[n] for n in ml_preds.keys()])\navg_ml = P_ml.mean(axis=1)\nensemble_results['SimpleAvg_ML'] = avg_ml\n\n# в”Җв”Җ D3: Simple Average (DL only) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nP_dl = np.column_stack([dl_preds[n] for n in dl_preds.keys()])\navg_dl = P_dl.mean(axis=1)\nensemble_results['SimpleAvg_DL'] = avg_dl\n\n# в”Җв”Җ D4: Best ML + Best DL average в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nbest_ml_name = max(ml_preds, key=lambda n: threshold_accuracy(y_actual, ml_preds[n], 5))\nbest_dl_name = max(dl_preds, key=lambda n: threshold_accuracy(y_actual, dl_preds[n], 5))\navg_best2    = (ml_preds[best_ml_name] + dl_preds[best_dl_name]) / 2\nensemble_results[f'Avg_{best_ml_name}+{best_dl_name}'] = avg_best2\n\nprint(f\"   Best ML model : {best_ml_name}\")\nprint(f\"   Best DL model : {best_dl_name}\")\n\n# в”Җв”Җ D5: Top-3 ML + Best DL в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\ntop3_ml = sorted(ml_preds, key=lambda n: threshold_accuracy(y_actual, ml_preds[n], 5),\n                 reverse=True)[:3]\ntop3_stack = np.column_stack([ml_preds[n] for n in top3_ml] +\n                              [dl_preds[best_dl_name]])\navg_top3_dl = top3_stack.mean(axis=1)\nensemble_results['Top3ML+BestDL'] = avg_top3_dl\n\n# в”Җв”Җ D6: Weighted: 70% Best ML + 30% Best DL в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nw_blend = 0.70 * ml_preds[best_ml_name] + 0.30 * dl_preds[best_dl_name]\nensemble_results['70%GB+30%RNN'] = w_blend\n\n# в”Җв”Җ D7: Weighted: 60% Best ML + 40% avg DL в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nw_blend2 = 0.60 * ml_preds[best_ml_name] + 0.40 * avg_dl\nensemble_results['60%GB+40%DL'] = w_blend2\n\n# ============================================================\n# 6E: Optimized Weight Ensemble\n# Find optimal weights via scipy minimize\n# ============================================================\nprint(\"\\nрҹ“Ң 6E: Optimized Weight Ensemble...\")\n\nopt_result, opt_found = load_checkpoint(\"step6_opt_weights\")\nif opt_found:\n    opt_weights = opt_result\nelse:\n    def neg_accuracy(weights):\n        weights = np.array(weights)\n        weights = np.abs(weights) / np.abs(weights).sum()\n        blended = P @ weights\n        return -threshold_accuracy(y_actual, blended, 5)\n\n    n_models = P.shape[1]\n    best_opt_acc = -999\n    best_weights = None\n\n    # Try multiple random starts\n    for seed in range(30):\n        np.random.seed(seed)\n        w0 = np.random.dirichlet(np.ones(n_models))\n        res = minimize(neg_accuracy, w0,\n                      method='SLSQP',\n                      bounds=[(0, 1)]*n_models,\n                      constraints={'type':'eq',\n                                   'fun': lambda w: np.sum(w)-1})\n        if res.fun < best_opt_acc or best_weights is None:\n            best_opt_acc = res.fun\n            best_weights = res.x\n\n    opt_weights = np.abs(best_weights) / np.abs(best_weights).sum()\n    save_checkpoint(\"step6_opt_weights\", opt_weights)\n\nopt_pred = P @ opt_weights\nensemble_results['OptimizedWeights'] = opt_pred\n\nprint(f\"   Optimized weights:\")\nfor i, (name, w) in enumerate(zip(model_names, opt_weights)):\n    print(f\"      {name:<22} вҶ’ {w*100:>5.1f}%\")\n\n# ============================================================\n# 6F: Stacking Ensemble (Ridge Meta-Learner)\n# Train meta-learner on ML model predictions using\n# out-of-fold strategy to avoid leakage\n# ============================================================\nprint(\"\\nрҹ“Ң 6F: Stacking Ensemble (Ridge Meta-Learner)...\")\n\nstack_result, stack_found = load_checkpoint(\"step6_stacking\")\nif stack_found:\n    stacking_pred = stack_result\nelse:\n    # Get ML predictions on TRAIN set (for meta-learner training)\n    ml_train_preds = {}\n    for name, model in zip(list(ml_preds.keys()),\n                           [load_checkpoint(f\"step4_model_{n}\")[0]['model']\n                            for n in ml_preds.keys()]):\n        train_pred_scaled = model.predict(X_train)\n        train_pred_actual = scaler_y.inverse_transform(\n                                train_pred_scaled.reshape(-1,1)).ravel()\n        ml_train_preds[name] = train_pred_actual\n\n    y_train_actual = scaler_y.inverse_transform(\n                         y_train.reshape(-1,1)).ravel()\n\n    # Stack ML train predictions as meta features\n    S_train = np.column_stack([ml_train_preds[n]\n                                for n in ml_preds.keys()])\n    S_test  = np.column_stack([ml_preds[n]\n                                for n in ml_preds.keys()])\n\n    # Add DL predictions to test stack\n    S_test_full  = np.column_stack(\n        [ml_preds[n] for n in ml_preds.keys()] +\n        [dl_preds[n] for n in dl_preds.keys()])\n\n    # Train Ridge meta-learner\n    meta = Ridge(alpha=1.0)\n    meta.fit(S_train, y_train_actual)\n\n    stacking_pred = meta.predict(S_test)\n    save_checkpoint(\"step6_stacking\", stacking_pred)\n\nensemble_results['Stacking_Ridge'] = stacking_pred\n\n# ============================================================\n# 6G: Per-Stock Best Model Ensemble\n# For each stock вҶ’ pick the best performing model\n# ============================================================\nprint(\"\\nрҹ“Ң 6G: Per-Stock Oracle Ensemble...\")\n\nper_stock_best, ps_found = load_checkpoint(\"step6_per_stock\")\nif ps_found:\n    per_stock_pred = ps_found\nelse:\n    per_stock_pred = np.zeros(len(y_actual))\n    stock_col      = test_df['Stock_Symbol'].values\n\n    for stock in stocks:\n        mask = stock_col == stock\n        best_name  = None\n        best_acc   = -1\n        for name in model_names:\n            acc = threshold_accuracy(y_actual[mask],\n                                     all_preds[name][mask], 5)\n            if acc > best_acc:\n                best_acc  = acc\n                best_name = name\n        per_stock_pred[mask] = all_preds[best_name][mask]\n        print(f\"      {stock:<20} вҶ’ {best_name:<22} Acc@5%: {best_acc:.2f}%\")\n\n    save_checkpoint(\"step6_per_stock\", per_stock_pred)\n\nensemble_results['PerStock_Best'] = per_stock_pred\n\n# ============================================================\n# 6H: Smart Weighted Ensemble\n# Weight = inverse MAPE per model (better model вҶ’ higher weight)\n# ============================================================\nprint(\"\\nрҹ“Ң 6H: Smart Inverse-MAPE Weighted Ensemble...\")\n\nmape_weights = {}\nfor name in model_names:\n    m = mape(y_actual, all_preds[name])\n    mape_weights[name] = 1.0 / (m + 1e-6)\n\ntotal_w = sum(mape_weights.values())\nmape_weights_norm = {n: w/total_w for n, w in mape_weights.items()}\n\nsmart_pred = sum(mape_weights_norm[n] * all_preds[n]\n                 for n in model_names)\nensemble_results['InverseMAPE_Weighted'] = smart_pred\n\nprint(\"   Inverse-MAPE weights:\")\nfor name, w in sorted(mape_weights_norm.items(),\n                       key=lambda x: -x[1]):\n    print(f\"      {name:<22} вҶ’ {w*100:>5.1f}%\")\n\n# ============================================================\n# 6I: Save All Ensemble Predictions\n# ============================================================\nresult, found = load_checkpoint(\"step6_all_ensembles\")\nif not found:\n    save_checkpoint(\"step6_all_ensembles\", {\n        'ensemble_results': ensemble_results,\n        'all_preds'       : all_preds,\n        'model_names'     : model_names,\n        'y_actual'        : y_actual,\n        'test_df'         : test_df\n    })\n\n# ============================================================\n# вң… RESULTS\n# ============================================================\nprint(\"\\n\" + \"=\"*60)\nprint(\"  рҹ“Ҡ ENSEMBLE RESULTS вҖ” OVERALL\")\nprint(\"=\"*60)\n\nprint(f\"\\n{'Model/Ensemble':<28} {'RMSE':>8} {'MAE':>8} \"\n      f\"{'MAPE%':>7} {'Acc@3%':>8} {'Acc@5%':>8} {'Acc@10%':>9}\")\nprint(\"-\"*80)\n\n# Print individual models first\nprint(\"  --- Individual Models ---\")\nfor name in model_names:\n    r   = rmse(y_actual, all_preds[name])\n    m   = mae(y_actual, all_preds[name])\n    mp  = mape(y_actual, all_preds[name])\n    a3  = threshold_accuracy(y_actual, all_preds[name], 3)\n    a5  = threshold_accuracy(y_actual, all_preds[name], 5)\n    a10 = threshold_accuracy(y_actual, all_preds[name], 10)\n    print(f\"  {name:<26} {r:>8.2f} {m:>8.2f} \"\n          f\"{mp:>7.2f}% {a3:>7.2f}% {a5:>7.2f}% {a10:>8.2f}%\")\n\n# Print ensembles\nprint(\"\\n  --- Ensemble Methods ---\")\nbest_ens_name = None\nbest_ens_acc  = 0\nall_ens_results = {}\n\nfor ens_name, preds in ensemble_results.items():\n    r   = rmse(y_actual, preds)\n    m   = mae(y_actual, preds)\n    mp  = mape(y_actual, preds)\n    a3  = threshold_accuracy(y_actual, preds, 3)\n    a5  = threshold_accuracy(y_actual, preds, 5)\n    a10 = threshold_accuracy(y_actual, preds, 10)\n    all_ens_results[ens_name] = {\n        'RMSE':r,'MAE':m,'MAPE':mp,\n        'Acc@3':a3,'Acc@5':a5,'Acc@10':a10,\n        'preds':preds\n    }\n    print(f\"  {ens_name:<26} {r:>8.2f} {m:>8.2f} \"\n          f\"{mp:>7.2f}% {a3:>7.2f}% {a5:>7.2f}% {a10:>8.2f}%\")\n    if a5 > best_ens_acc:\n        best_ens_acc  = a5\n        best_ens_name = ens_name\n\nprint(f\"\\n  рҹҸҶ Best Ensemble : {best_ens_name} вҶ’ {best_ens_acc:.2f}%\")\n\n# ============================================================\n# PER-COMPANY TABLE\n# ============================================================\nprint(\"\\n\" + \"=\"*60)\nprint(\"  рҹ“Ҳ PER-COMPANY ACCURACY (Acc@5%) вҖ” Top Ensembles vs Paper\")\nprint(\"=\"*60)\n\n# Pick top 4 ensembles + best individual ML\ntop_ens = sorted(all_ens_results,\n                 key=lambda x: all_ens_results[x]['Acc@5'],\n                 reverse=True)[:4]\nshow_cols = [best_ml_name] + top_ens\n\nheader = f\"  {'Company':<18}\"\nfor c in show_cols:\n   