        100.00%\n     ICICIBANK.NS         вҶ’ LightGBM             100.00%\n     LT.NS                вҶ’ Ridge                100.00%\n     TCS.NS               вҶ’ LightGBM             99.32%\n     WIPRO.NS             вҶ’ GradientBoosting     99.32%\n\n============================================================\n  рҹ“° COMPARISON WITH BASE PAPER\n============================================================\n  Paper Ensemble Accuracy  : 91.89%\n  Our Best ML Accuracy     : 95.15%\n  вң… We BEAT the paper by   : 3.26%\n\nвң… STEP 4 COMPLETE вҖ” Move to Step 5: Deep Learning!\n============================================================\n","output_type":"stream"}],"execution_count":5},{"cell_type":"code","source":"# ============================================================\n# STEP 5: Deep Learning вҖ” LSTM, GRU, BiLSTM, RNN\n# 60-day sequence window | Per-stock sequences | Full resume\n# ============================================================\n\nimport os, pickle, warnings, time\nimport numpy as np\nimport pandas as pd\nimport tensorflow as tf\nfrom tensorflow.keras.models     import Sequential, load_model\nfrom tensorflow.keras.layers     import (LSTM, GRU, Dense, Dropout,\n                                          Bidirectional, SimpleRNN,\n                                          BatchNormalization)\nfrom tensorflow.keras.callbacks  import (EarlyStopping, ModelCheckpoint,\n                                          ReduceLROnPlateau, CSVLogger)\nfrom tensorflow.keras.optimizers import Adam\n\nwarnings.filterwarnings('ignore')\ntf.get_logger().setLevel('ERROR')\n\nCHECKPOINT  = \"/kaggle/working/checkpoints\"\nDL_WEIGHTS  = \"/kaggle/working/dl_weights\"    # Keras .h5 weight files\nDL_LOGS     = \"/kaggle/working/dl_logs\"       # CSV training logs\nos.makedirs(CHECKPOINT, exist_ok=True)\nos.makedirs(DL_WEIGHTS,  exist_ok=True)\nos.makedirs(DL_LOGS,     exist_ok=True)\n\n\ndef save_checkpoint(name, obj):\n    path = os.path.join(CHECKPOINT, f\"{name}.pkl\")\n    with open(path, 'wb') as f: pickle.dump(obj, f)\n    print(f\"  вң… Saved: {name}.pkl\")\n\ndef load_checkpoint(name):\n    path = os.path.join(CHECKPOINT, f\"{name}.pkl\")\n    if os.path.exists(path):\n        with open(path, 'rb') as f: obj = pickle.load(f)\n        print(f\"  вҸ© Resuming: {name}.pkl\")\n        return obj, True\n    return None, False\n\ndef threshold_accuracy(actual, predicted, threshold=5.0):\n    pct_error = np.abs((actual - predicted) / actual) * 100\n    return (pct_error <= threshold).mean() * 100\n\ndef rmse(actual, predicted):\n    return np.sqrt(np.mean((actual - predicted) ** 2))\n\ndef mape(actual, predicted):\n    return np.mean(np.abs((actual - predicted) / actual)) * 100\n\nprint(\"\\n\" + \"=\"*60)\nprint(\"  STEP 5: Deep Learning Models\")\nprint(\"=\"*60)\n\n# в”Җв”Җ Load Step 3 data в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nstep3, _     = load_checkpoint(\"step3_data\")\nscaler_X     = step3['scaler_X']\nscaler_y     = step3['scaler_y']\nfeature_cols = step3['feature_cols']\ntrain_df     = step3['train_df']\ntest_df      = step3['test_df']\n\ny_test_actual = scaler_y.inverse_transform(\n                    step3['y_test'].reshape(-1,1)).ravel()\n\nSEQ_LEN    = 60    # 60-day window (same as paper)\nN_FEATURES = len(feature_cols)\nBATCH_SIZE = 64\nMAX_EPOCHS = 100   # EarlyStopping will stop early\n\n# ============================================================\n# 5A: Build Sequences (per stock вҖ” no cross-stock mixing)\n# ============================================================\nprint(\"\\nрҹ“Ң 5A: Building Sequences...\")\n\nseq_result, seq_found = load_checkpoint(\"step5_sequences\")\nif seq_found:\n    X_seq_train = seq_result['X_seq_train']\n    y_seq_train = seq_result['y_seq_train']\n    X_seq_test  = seq_result['X_seq_test']\n    y_seq_test  = seq_result['y_seq_test']\n    test_seq_meta = seq_result['test_seq_meta']\nelse:\n    def make_sequences(df, seq_len, feature_cols, target_col='Target'):\n        \"\"\"\n        Build sequences per stock.\n        For test set: we include the LAST seq_len rows of train\n        per stock as seed so first test prediction is valid.\n        \"\"\"\n        X_list, y_list, meta_list = [], [], []\n        stocks = df['Stock_Symbol'].unique()\n        for stock in stocks:\n            sdf = df[df['Stock_Symbol'] == stock].sort_values('Date')\n            vals   = scaler_X.transform(sdf[feature_cols].values)\n            target = scaler_y.transform(\n                         sdf[target_col].values.reshape(-1,1)).ravel()\n            for i in range(seq_len, len(sdf)):\n                X_list.append(vals[i-seq_len:i])\n                y_list.append(target[i])\n                meta_list.append({\n                    'stock': stock,\n                    'date' : sdf.iloc[i]['Date']\n                })\n        return (np.array(X_list, dtype=np.float32),\n                np.array(y_list,  dtype=np.float32),\n                pd.DataFrame(meta_list))\n\n    def make_test_sequences(train_df, test_df, seq_len, feature_cols):\n        \"\"\"\n        Test sequences: seed from tail of train per stock.\n        This ensures first test prediction has full 60-day history.\n        \"\"\"\n        X_list, y_list, meta_list = [], [], []\n        stocks = test_df['Stock_Symbol'].unique()\n        for stock in stocks:\n            tr = train_df[train_df['Stock_Symbol']==stock].sort_values('Date')\n            te = test_df[test_df['Stock_Symbol']==stock].sort_values('Date')\n            # Combine tail of train + all test for this stock\n            combined = pd.concat([tr.tail(seq_len), te], ignore_index=True)\n            vals   = scaler_X.transform(combined[feature_cols].values)\n            target = scaler_y.transform(\n                         combined['Target'].values.reshape(-1,1)).ravel()\n            # Sequences only from test portion\n            n_train_rows = min(seq_len, len(tr))\n            for i in range(n_train_rows, len(combined)):\n                if i < seq_len:\n                    continue\n                X_list.append(vals[i-seq_len:i])\n                y_list.append(target[i])\n                meta_list.append({\n                    'stock': stock,\n                    'date' : combined.iloc[i]['Date']\n                })\n        return (np.array(X_list, dtype=np.float32),\n                np.array(y_list,  dtype=np.float32),\n                pd.DataFrame(meta_list))\n\n    print(\"   Building train sequences...\")\n    X_seq_train, y_seq_train, _ = make_sequences(\n        train_df, SEQ_LEN, feature_cols)\n\n    print(\"   Building test sequences (with train seed)...\")\n    X_seq_test, y_seq_test, test_seq_meta = make_test_sequences(\n        train_df, test_df, SEQ_LEN, feature_cols)\n\n    print(f\"   X_seq_train : {X_seq_train.shape}\")\n    print(f\"   X_seq_test  : {X_seq_test.shape}\")\n    print(f\"   y_seq_train : {y_seq_train.shape}\")\n    print(f\"   y_seq_test  : {y_seq_test.shape}\")\n\n    save_checkpoint(\"step5_sequences\", {\n        'X_seq_train' : X_seq_train,\n        'y_seq_train' : y_seq_train,\n        'X_seq_test'  : X_seq_test,\n        'y_seq_test'  : y_seq_test,\n        'test_seq_meta': test_seq_meta\n    })\n\ny_seq_test_actual = scaler_y.inverse_transform(\n                        y_seq_test.reshape(-1,1)).ravel()\n\n# ============================================================\n# 5B: Model Definitions\n# ============================================================\ndef build_lstm(seq_len, n_features):\n    model = Sequential([\n        LSTM(64, return_sequences=True,\n             input_shape=(seq_len, n_features)),\n        BatchNormalization(),\n        Dropout(0.2),\n        LSTM(64, return_sequences=False),\n        BatchNormalization(),\n        Dropout(0.2),\n        Dense(32, activation='relu'),\n        Dropout(0.1),\n        Dense(1)\n    ], name='LSTM')\n    model.compile(optimizer=Adam(0.001), loss='mse',\n                  metrics=['mae'])\n    return model\n\ndef build_gru(seq_len, n_features):\n    model = Sequential([\n        GRU(64, return_sequences=True,\n            input_shape=(seq_len, n_features)),\n        BatchNormalization(),\n        Dropout(0.2),\n        GRU(64, return_sequences=False),\n        BatchNormalization(),\n        Dropout(0.2),\n        Dense(32, activation='relu'),\n        Dropout(0.1),\n        Dense(1)\n    ], name='GRU')\n    model.compile(optimizer=Adam(0.001), loss='mse',\n                  metrics=['mae'])\n    return model\n\ndef build_bilstm(seq_len, n_features):\n    model = Sequential([\n        Bidirectional(LSTM(64, return_sequences=True),\n                      input_shape=(seq_len, n_features)),\n        BatchNormalization(),\n        Dropout(0.2),\n        Bidirectional(LSTM(64, return_sequences=False)),\n        BatchNormalization(),\n        Dropout(0.2),\n        Dense(32, activation='relu'),\n        Dropout(0.1),\n        Dense(1)\n    ], name='BiLSTM')\n    model.compile(optimizer=Adam(0.001), loss='mse',\n                  metrics=['mae'])\n    return model\n\ndef build_rnn(seq_len, n_features):\n    model = Sequential([\n        SimpleRNN(64, return_sequences=True,\n                  input_shape=(seq_len, n_features)),\n        BatchNormalization(),\n        Dropout(0.2),\n        SimpleRNN(64, return_sequences=False),\n        BatchNormalization(),\n        Dropout(0.2),\n        Dense(32, activation='relu'),\n        Dropout(0.1),\n        Dense(1)\n    ], name='RNN')\n    model.compile(optimizer=Adam(0.001), loss='mse',\n                  metrics=['mae'])\n    return model\n\nmodel_builders = {\n    'LSTM'  : build_lstm,\n    'GRU'   : build_gru,\n    'BiLSTM': build_bilstm,\n    'RNN'   : build_rnn,\n}\n\n# ============================================================\n# 5C: Train Each DL Model with Full Resume Support\n# в”Җв”Җ Weight file saves after every epoch via ModelCheckpoint\n# в”Җв”Җ If training interrupted вҶ’ weights auto-reloaded\n# в”Җв”Җ If fully trained вҶ’ predictions loaded from checkpoint\n# ============================================================\nprint(\"\\nрҹ“Ң 5C: Training DL Models...\")\n\ndl_predictions  = {}\ndl_histories    = {}\n\nfor model_name, builder in model_builders.items():\n\n    print(f\"\\n{'='*50}\")\n    print(f\"  рҹ”„ {model_name}\")\n    print(f\"{'='*50}\")\n\n    pred_ck  = f\"step5_preds_{model_name}\"\n    hist_ck  = f\"step5_hist_{model_name}\"\n    wt_path  = os.path.join(DL_WEIGHTS, f\"{model_name}_best.weights.h5\")\n    log_path = os.path.join(DL_LOGS,    f\"{model_name}_log.csv\")\n\n    # в”Җв”Җ If predictions already saved вҶ’ skip entirely в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    preds_saved, pred_found = load_checkpoint(pred_ck)\n    if pred_found:\n        dl_predictions[model_name] = preds_saved\n        hist_saved, _ = load_checkpoint(hist_ck)\n        if hist_saved:\n            dl_histories[model_name] = hist_saved\n        print(f\"  вҸ© {model_name} predictions loaded вҖ” skipping training\")\n        continue\n\n    # в”Җв”Җ Build model в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    model = builder(SEQ_LEN, N_FEATURES)\n\n    # в”Җв”Җ Resume from weights if interrupted mid-training в”Җв”Җв”Җв”Җв”Җв”Җ\n    if os.path.exists(wt_path):\n        print(f\"  вҡЎ Resuming weights from {wt_path}\")\n        model.load_weights(wt_path)\n\n    # в”Җв”Җ Callbacks в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    callbacks = [\n        EarlyStopping(\n            monitor   = 'val_loss',\n            patience  = 15,\n            restore_best_weights = True,\n            verbose   = 1\n        ),\n        ModelCheckpoint(\n            filepath          = wt_path,\n            monitor           = 'val_loss',\n            save_best_only    = True,\n            save_weights_only = True,\n            verbose           = 0\n        ),\n        ReduceLROnPlateau(\n            monitor  = 'val_loss',\n            factor   = 0.5,\n            patience = 7,\n            min_lr   = 1e-6,\n            verbose  = 1\n        ),\n        CSVLogger(log_path, append=True)  # append=True for resume\n    ]\n\n    # в”Җв”Җ Train в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    t0 = time.time()\n    history = model.fit(\n        X_seq_train, y_seq_train,\n        validation_split = 0.15,\n        epochs           = MAX_EPOCHS,\n        batch_size       = BATCH_SIZE,\n        callbacks        = callbacks,\n        verbose          = 1\n    )\n    elapsed = time.time() - t0\n    print(f\"  вҸұ  Training time: {elapsed:.1f}s\")\n\n    # в”Җв”Җ Load best weights (EarlyStopping already restores) в”Җв”Җв”Җ\n    if os.path.exists(wt_path):\n        model.load_weights(wt_path)\n\n    # в”Җв”Җ Predict в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    preds_scaled = model.predict(X_seq_test, verbose=0).ravel()\n    preds_actual = scaler_y.inverse_transform(\n                       preds_scaled.reshape(-1,1)).ravel()\n\n    dl_predictions[model_name]  = preds_actual\n    dl_histories[model_name]    = history.history\n\n    save_checkpoint(pred_ck,  preds_actual)\n    save_checkpoint(hist_ck,  history.history)\n\n    # Quick metric print\n    acc = threshold_accuracy(y_seq_test_actual, preds_actual, 5)\n    r   = rmse(y_seq_test_actual, preds_actual)\n    print(f\"  рҹ“Ҡ Quick Check вҶ’ RMSE: {r:.2f}  |  Acc@5%: {acc:.2f}%\")\n\n# ============================================================\n# 5D: Save All DL Predictions\n# ============================================================\nresult_dl, found_dl = load_checkpoint(\"step5_all_dl\")\nif not found_dl:\n    save_checkpoint(\"step5_all_dl\", {\n        'dl_predictions'   : dl_predictions,\n        'y_seq_test_actual': y_seq_test_actual,\n        'test_seq_meta'    : test_seq_meta\n    })\n\nprint(\"\\n\" + \"=\"*60)\nprint(\"  вң… ALL DL MODELS TRAINED\")\nprint(\"=\"*60)\n\n# ============================================================\n# в”Җв”Җ OPTIONAL ACCURACY BLOCK в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nSHOW_ACCURACY = True   # вҶҗ set False to skip\n\nif SHOW_ACCURACY:\n\n    print(\"\\n\" + \"=\"*60)\n    print(\"  рҹ“Ҡ DL MODEL ACCURACY RESULTS\")\n    print(\"=\"*60)\n\n    print(f\"\\n{'Model':<10} {'RMSE':>8} {'MAPE%':>8} \"\n          f\"{'Acc@3%':>8} {'Acc@5%':>8} {'Acc@10%':>9}\")\n    print(\"-\"*55)\n\n    dl_overall = {}\n    for mn, preds in dl_predictions.items():\n        r   = rmse(y_seq_test_actual, preds)\n        mp  = mape(y_seq_test_actual, preds)\n        a3  = threshold_accuracy(y_seq_test_actual, preds, 3)\n        a5  = threshold_accuracy(y_seq_test_actual, preds, 5)\n        a10 = threshold_accuracy(y_seq_test_actual, preds, 10)\n        dl_overall[mn] = {'RMSE':r,'MAPE':mp,'Acc@3':a3,'Acc@5':a5,'Acc@10':a10}\n        print(f\"{mn:<10} {r:>8.2f} {mp:>8.2f}% \"\n              f\"{a3:>7.2f}% {a5:>7.2f}% {a10:>8.2f}%\")\n\n    best_dl = max(dl_overall, key=lambda x: dl_overall[x]['Acc@5'])\n    print(f\"\\n  рҹҸҶ Best DL Model (Acc@5%) : {best_dl} \"\n          f\"вҶ’ {dl_overall[best_dl]['Acc@5']:.2f}%\")\n\n    # в”Җв”Җ Per-Company Table в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    print(\"\\n\" + \"=\"*60)\n    print(\"  рҹ“Ҳ PER-COMPANY ACCURACY (Acc@5%) вҖ” All DL Models\")\n    print(\"=\"*60)\n\n    stocks = sorted(test_seq_meta['stock'].unique())\n\n    header = f\"{'Company':<18}\"\n    for mn in dl_predictions.keys():\n        header += f\" {mn:>10}\"\n    print(header)\n    print(\"-\" * (18 + 11 * len(dl_predictions)))\n\n    per_company_dl = {}\n    for stock in stocks:\n        mask = test_seq_meta['stock'].values == stock\n        actual_s = y_seq_test_actual[mask]\n        row = f\"{stock:<18}\"\n        per_company_dl[stock] = {}\n        for mn, preds in dl_predictions.items():\n            preds_s = preds[mask]\n            acc = threshold_accuracy(actual_s, preds_s, 5)\n            per_company_dl[stock][mn] = acc\n            row += f\" {acc:>9.2f}%\"\n        print(row)\n\n    # Average row\n    print(\"-\" * (18 + 11 * len(dl_predictions)))\n    avg_row = f\"{'AVERAGE':<18}\"\n    for mn in dl_predictions.keys():\n        avg = np.mean([per_company_dl[s][mn] for s in stocks])\n        avg_row += f\" {avg:>9.2f}%\"\n    print(avg_row)\n\n    # в”Җв”Җ Paper Comparison в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    print(\"\\n\" + \"=\"*60)\n    print(\"  рҹ“° COMPARISON WITH BASE PAPER\")\n    print(\"=\"*60)\n    paper_acc = 91.89\n    for mn, res in dl_overall.items():\n        gap = res['Acc@5'] - paper_acc\n        status = \"вң… BEATS paper\" if gap >= 0 else \"рҹ“ү Below paper\"\n        print(f\"  {mn:<10} Acc@5%: {res['Acc@5']:.2f}%  \"\n              f\"| {status} by {abs(gap):.2f}%\")\n\nprint(\"\\nвң… STEP 5 COMPLETE вҖ” Move to Step 6: Ensemble!\")\nprint(\"=\"*60)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-24T08:45:05.600161Z","iopub.execute_input":"2026-04-24T08:45:05.600890Z","iopub.status.idle":"2026-04-24T08:51:13.477378Z","shell.execute_reply.started":"2026-04-24T08:45:05.600854Z","shell.execute_reply":"2026-04-24T08:51:13.476331Z"}},"outputs":[{"name":"stderr","text":"2026-04-24 08:45:07.422345: E external/local_xla/xla/stream_executor/cuda/cuda_fft.cc:467] Unable to register cuFFT factory: Attempting to register factory for plugin cuFFT when one has already been registered\nWARNING: