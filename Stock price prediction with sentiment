 f\"{name}.pkl\")\n    if os.path.exists(path):\n        with open(path, 'rb') as f:\n            obj = pickle.load(f)\n        print(f\"  вҸ© Checkpoint loaded: {name}.pkl  [RESUMING]\")\n        return obj, True\n    return None, False\n\n# в”Җв”Җ Load Data в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nprint(\"\\n\" + \"=\"*60)\nprint(\"  STEP 1: Loading Datasets\")\nprint(\"=\"*60)\n\nresult, found = load_checkpoint(\"step1_raw_data\")\nif found:\n    stock_df, news_df = result\nelse:\n    stock_df = pd.read_csv(STOCK_PATH)\n    news_df  = pd.read_csv(NEWS_PATH)\n    save_checkpoint(\"step1_raw_data\", (stock_df, news_df))\n\n# в”Җв”Җ Verification в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nprint(\"\\nрҹ“Ҡ STOCK DATASET:\")\nprint(f\"   Shape        : {stock_df.shape}\")\nprint(f\"   Date Range   : {stock_df['Date'].min()}  вҶ’  {stock_df['Date'].max()}\")\nprint(f\"   Stocks       : {stock_df['Stock_Symbol'].nunique()} unique symbols\")\nprint(f\"   Missing vals : {stock_df.isnull().sum().sum()} total\")\nprint(f\"   Target stats : min={stock_df['Target'].min():.2f}, max={stock_df['Target'].max():.2f}, mean={stock_df['Target'].mean():.2f}\")\n\nprint(\"\\nрҹ“° NEWS DATASET:\")\nprint(f\"   Shape         : {news_df.shape}\")\nprint(f\"   Date Range    : {news_df['post_date_ist'].min()}  вҶ’  {news_df['post_date_ist'].max()}\")\nprint(f\"   Unique sectors: {news_df['classified_sector'].nunique()}\")\nprint(f\"   FinBERT score : min={news_df['finbert_score'].min():.3f}, max={news_df['finbert_score'].max():.3f}, mean={news_df['finbert_score'].mean():.3f}\")\nprint(f\"   FinBERT labels: {news_df['finbert_label'].value_counts().to_dict()}\")\nprint(f\"   Missing vals  : {news_df.isnull().sum().sum()} total\")\n\nprint(\"\\nрҹ“Ӣ STOCK COLUMNS:\")\nprint(list(stock_df.columns))\n\nprint(\"\\nрҹ“Ӣ NEWS COLUMNS:\")\nprint(list(news_df.columns))\n\nprint(\"\\nрҹ”Қ SAMPLE STOCK DATA (first 3 rows):\")\nprint(stock_df.head(3).to_string())\n\nprint(\"\\nрҹ”Қ SAMPLE NEWS DATA (first 3 rows):\")\nprint(news_df[['post_date_ist','headline','classified_sector','finbert_score','finbert_label']].head(3).to_string())\n\nprint(\"\\nвң… STEP 1 COMPLETE вҖ” Data loaded and verified successfully!\")\nprint(\"=\"*60)","metadata":{"_uuid":"8f2839f25d086af736a60e9eeb907d3b93b6e0e5","_cell_guid":"b1076dfc-b9ad-4769-8c92-a6c4dae69d19","trusted":true,"execution":{"iopub.status.busy":"2026-04-24T08:43:26.661293Z","iopub.execute_input":"2026-04-24T08:43:26.661603Z","iopub.status.idle":"2026-04-24T08:43:27.247661Z","shell.execute_reply.started":"2026-04-24T08:43:26.661577Z","shell.execute_reply":"2026-04-24T08:43:27.246835Z"}},"outputs":[{"name":"stdout","text":"\n============================================================\n  STEP 1: Loading Datasets\n============================================================\n  вң… Checkpoint saved: step1_raw_data.pkl\n\nрҹ“Ҡ STOCK DATASET:\n   Shape        : (8140, 27)\n   Date Range   : 2021-01-01  вҶ’  2023-12-28\n   Stocks       : 11 unique symbols\n   Missing vals : 0 total\n   Target stats : min=166.60, max=6575.80, mean=1656.90\n\nрҹ“° NEWS DATASET:\n   Shape         : (52697, 17)\n   Date Range    : 2021-01-01  вҶ’  2023-12-31\n   Unique sectors: 11\n   FinBERT score : min=-0.940, max=0.937, mean=0.301\n   FinBERT labels: {'Positive': 31314, 'Negative': 11287, 'Neutral': 10096}\n   Missing vals  : 149 total\n\nрҹ“Ӣ STOCK COLUMNS:\n['Date', 'Open_Price', 'High_Price', 'Low_Price', 'Close_Price', 'Volume', 'Stock_Symbol', 'SMA_7', 'SMA_14', 'SMA_50', 'Daily_Return_Pct', 'ATR_14', 'RSI_14', 'VWAP_14', '52W_High', '52W_Low', 'Dist_From_52W_High_Pct', 'Volatility_20D', 'Crude_Oil_Price', 'USD_INR_Exchange_Rate', 'India_VIX', 'Gold_Price', 'Nifty50_Close', 'Repo_Rate', 'Inflation_CPI', 'Target', 'Target_Return']\n\nрҹ“Ӣ NEWS COL