e           Telecom       0.726944      Positive\n1    2021-01-02      the 2021 holiday dreamlist by unusual luxury journeys into indias hinterland           General       0.391709      Positive\n2    2021-01-02      heres all you need to know about the term insurance policy saral jeevan bima              Auto       0.909040      Positive\n\nвң… STEP 1 COMPLETE вҖ” Data loaded and verified successfully!\n============================================================\n","output_type":"stream"}],"execution_count":2},{"cell_type":"code","source":"# ============================================================\n# STEP 2: Preprocessing + Merging + Composite Sentiment Score\n# ============================================================\n\nimport os, pickle, warnings\nimport numpy as np\nimport pandas as pd\nfrom sklearn.preprocessing import MinMaxScaler\n\nwarnings.filterwarnings('ignore')\n\nBASE_DIR   = \"/kaggle/working\"\nCHECKPOINT = os.path.join(BASE_DIR, \"checkpoints\")\nos.makedirs(CHECKPOINT, exist_ok=True)\n\ndef save_checkpoint(name, obj):\n    path = os.path.join(CHECKPOINT, f\"{name}.pkl\")\n    with open(path, 'wb') as f: pickle.dump(obj, f)\n    print(f\"  вң… Saved: {name}.pkl\")\n\ndef load_checkpoint(name):\n    path = os.path.join(CHECKPOINT, f\"{name}.pkl\")\n    if os.path.exists(path):\n        with open(path, 'rb') as f: obj = pickle.load(f)\n        print(f\"  вҸ© Resuming from: {name}.pkl\")\n        return obj, True\n    return None, False\n\nprint(\"\\n\" + \"=\"*60)\nprint(\"  STEP 2: Preprocessing + Merging + Sentiment Score\")\nprint(\"=\"*60)\n\n# в”Җв”Җ Check if Step 2 already done в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nresult, found = load_checkpoint(\"step2_final_df\")\nif found:\n    final_df = result\nelse:\n    # в”Җв”Җ Load from Step 1 checkpoint в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    (stock_df, news_df), _ = load_checkpoint(\"step1_raw_data\"), True\n    result, _              = load_checkpoint(\"step1_raw_data\")\n    stock_df, news_df      = result\n\n    # ============================================================\n    # 2A: Clean Stock Data\n    # ============================================================\n    print(\"\\nрҹ“Ң 2A: Cleaning Stock Data...\")\n\n    stock_df['Date'] = pd.to_datetime(stock_df['Date'])\n    stock_df = stock_df.sort_values(['Stock_Symbol', 'Date']).reset_index(drop=True)\n\n    # Drop Target_Return (we only predict next day Close Price = Target)\n    if 'Target_Return' in stock_df.columns:\n        stock_df = stock_df.drop(columns=['Target_Return'])\n\n    # Fill any remaining nulls with forward fill then backward fill\n    stock_df = stock_df.groupby('Stock_Symbol', group_keys=False).apply(\n        lambda g: g.fillna(method='ffill').fillna(method='bfill')\n    )\n\n    print(f\"   Stock shape after clean : {stock_df.shape}\")\n    print(f\"   Missing values          : {stock_df.isnull().sum().sum()}\")\n\n    # ============================================================\n    # 2B: Clean News Data\n    # ============================================================\n    print(\"\\nрҹ“Ң 2B: Cleaning News Data...\")\n\n    news_df['post_date_ist'] = pd.to_datetime(news_df['post_date_ist'])\n\n    # Drop rows where finbert_score is null (149 missing)\n    news_df = news_df.dropna(subset=['finbert_score'])\n    print(f\"   News shape after dropping null finbert: {news_df.shape}\")\n\n    # ============================================================\n    # 2C: Aggregate News by Date\n    # в”Җв”Җ We merge on Date only (no Sector column in stock data)\n    # в”Җв”Җ For each date: mean finbert_score, dominant label,\n    #                   news count (volume of news = market attention)\n    # ============================================================\n    print(\"\\nрҹ“Ң 2C: Aggregating News by Date...\")\n\n    news_daily = news_df.groupby('post_date_ist').agg(\n        finbert_score_mean = ('finbert_score', 'mean'),\n        finbert_score_max  = ('finbert_score', 'max'),\n        finbert_score_min  = ('finbert_score', 'min'),\n        finbert_score_std  = ('finbert_score', 'std'),   # sentiment uncertainty\n        news_count         = ('finbert_score', 'count'), # how many news that day\n        positive_ratio     = ('finbert_label', lambda x: (x=='Positive').sum() / len(x)),\n        negative_ratio     = ('finbert_label', lambda x: (x=='Negative').sum() / len(x)),\n        neutral_ratio      = ('finbert_label', lambda x: (x=='Neutral').sum()  / len(x)),\n    ).reset_index()\n\n    news_daily.columns = ['Date', 'finbert_score_mean', 'finbert_score_max',\n                          'finbert_score_min', 'finbert_score_std', 'news_count',\n                          'positive_ratio', 'negative_ratio', 'neutral_ratio']\n\n    # Fill std NaN (days with single news)\n    news_daily['finbert_score_std'] = news_daily['finbert_score_std'].fillna(0)\n\n    print(f\"   Daily news aggregated shape : {news_daily.shape}\")\n    print(f\"   Date range in news          : {news_daily['Date'].min()} вҶ’ {news_daily['Date'].max()}\")\n\n    # ============================================================\n    # 2D: Merge Stock + News on Date\n    # ============================================================\n    print(\"\\nрҹ“Ң 2D: Merging Stock Data with Daily News Sentiment...\")\n\n    merged_df = pd.merge(stock_df, news_daily, on='Date', how='left')\n\n    # Days with no news вҶ’ fill with neutral values\n    merged_df['finbert_score_mean'] = merged_df['finbert_score_mean'].fillna(0.0)\n    merged_df['finbert_score_max']  = merged_df['finbert_score_max'].fillna(0.0)\n    merged_df['finbert_score_min']  = merged_df['finbert_score_min'].fillna(0.0)\n    merged_df['finbert_score_std']  = merged_df['finbert_score_std'].fillna(0.0)\n    merged_df['news_count']         = merged_df['news_count'].fillna(0).astype(int)\n    merged_df['positive_ratio']     = merged_df['positive_ratio'].fillna(0.333)\n    merged_df['negative_ratio']     = merged_df['negative_ratio'].fillna(0.333)\n    merged_df['neutral_ratio']      = merged_df['neutral_ratio'].fillna(0.334)\n\n    print(f\"   Merged shape              : {merged_df.shape}\")\n    print(f\"   Missing after merge       : {merged_df.isnull().sum().sum()}\")\n    days_no_news = (merged_df['news_count'] == 0).sum()\n    print(f\"   Stock rows with no news   : {days_no_news}\")\n\n    # ============================================================\n    # 2E: Composite Sentiment Score\n    # Weights: FinBERT=30%, VIX=20%, Nifty=15%,\n    #          Crude=10%, USD/INR=10%, Gold=5%, Repo=5%, CPI=5%\n    # ============================================================\n    print(\"\\nрҹ“Ң 2E: Building Composite Sentiment Score...\")\n\n    scaler = MinMaxScaler()\n\n    macro_cols = ['India_VIX', 'Crude_Oil_Price', 'USD_INR_Exchange_Rate',\n                  'Gold_Price', 'Nifty50_Close', 'Repo_Rate', 'Inflation_CPI']\n\n    temp = merged_df.copy()\n\n    # Normalize macro cols вҶ’ [0, 1]\n    temp[macro_cols] = scaler.fit_transform(merged_df[macro_cols])\n\n    # Normalize finbert_score from [-1,+1] вҶ’ [0,1]\n    temp['finbert_norm'] = (merged_df['finbert_score_mean'] + 1) / 2\n\n    # Direction signals\n    # Bearish factors вҶ’ invert  |  Bullish factors вҶ’ keep\n    temp['vix_signal']   = 1 - temp['India_VIX']             # fear вҶ‘ = bad вҶ’ invert\n    temp['crude_signal'] = 1 - temp['Crude_Oil_Price']        # cost вҶ‘ = bad вҶ’ invert\n    temp['usd_signal']   = 1 - temp['USD_INR_Exchange_Rate']  # INR weak = bad вҶ’ invert\n    temp['gold_signal']  = 1 - temp['Gold_Price']             # safe haven вҶ‘ = bad вҶ’ invert\n    temp['nifty_signal'] = temp['Nifty50_Close']              # market вҶ‘ = good вҶ’ keep\n    temp['repo_signal']  = 1 - temp['Repo_Rate']              # rate вҶ‘ = bad вҶ’ invert\n    temp['cpi_signal']   = 1 - temp['Inflation_CPI']          # inflation вҶ‘ = bad вҶ’ invert\n\n    # Weighted Composite Score\n    merged_df['Composite_Sentiment_Score'] = (\n        0.30 * temp['finbert_norm']   +\n        0.20 * temp['vix_signal']     +\n        0.15 * temp['nifty_signal']   +\n        0.10 * temp['crude_signal']   +\n        0.10 * temp['usd_signal']     +\n        0.05 * temp['gold_signal']    +\n        0.05 * temp['repo_signal']    +\n        0.05 * temp['cpi_signal']\n    )\n\n    # Label\n    def label_sentiment(score):\n        if score >= 0.65:   return 'Strong Bullish'\n        elif score >= 0.55: return 'Bullish'\n        elif score >= 0.45: return 'Neutral'\n        elif score >= 0.35: return 'Bearish'\n        else:               return 'Strong Bearish'\n\n    merged_df['Composite_Sentiment_Label'] = merged_df['Composite_Sentiment_Score'].apply(label_sentiment)\n\n    # ============================================================\n    # 2F: Save Final DataFrame\n    # ============================================================\n    final_df = merged_df.copy()\n    save_checkpoint(\"step2_final_df\", final_df)\n\n# ============================================================\n# вң… VERIFICATION\n# ============================================================\nprint(\"\\n\" + \"=\"*60)\nprint(\"  STEP 2 VERIFICATION\")\nprint(\"=\"*60)\n\nprint(f\"\\nрҹ“җ Final DataFrame Shape  : {final_df.shape}\")\nprint(f\"рҹ“… Date Range             : {final_df['Date'].min()} вҶ’ {final_df['Date'].max()}\")\nprint(f\"рҹ“Ҳ Unique Stocks          : {final_df['Stock_Symbol'].nunique()}\")\nprint(f\"рҹ”ў Total Features         : {final_df.shape[1]}\")\nprint(f\"вқҢ Missing Values         : {final_df.isnull().sum().sum()}\")\n\nprint(f\"\\nрҹ“Ҡ Composite Sentiment Score Stats:\")\nprint(f\"   Min   : {final_df['Composite_Sentiment_Score'].min():.4f}\")\nprint(f\"   Max   : {final_df['Composite_Sentiment_Score'].max():.4f}\")\nprint(f\"   Mean  : {final_df['Composite_Sentiment_Score'].mean():.4f}\")\nprint(f\"   Std   : {final_df['Composite_Sentiment_Score'].std():.4f}\")\n\nprint(f\"\\nрҹҸ·пёҸ  Sentiment Label Distribution:\")\nprint(final_df['Composite_Sentiment_Label'].value_counts().to_string())\n\nprint(f\"\\nрҹ“° News Coverage:\")\nprint(f\"   Days with news     : {(final_df['news_count'] > 0).sum()}\")\nprint(f\"   Days without news  : {(final_df['news_count'] == 0).sum()}\")\nprint(f\"   Avg news per day   : {final_df['news_count'].mean():.2f}\")\n\nprint(f\"\\nрҹ“Ӣ New Columns Added:\")\nnew_cols = ['finbert_score_mean','finbert_score_max','finbert_score_min',\n            'finbert_score_std','news_count','positive_ratio','negative_ratio',\n            'neutral_ratio','Composite_Sentiment_Score','Composite_Sentiment_Label']\nfor c in new_cols:\n    print(f\"   вң” {c}\")\n\nprint(f\"\\nрҹ”Қ Sample Rows (Composite Score):\")\nprint(final_df[['Date','Stock_Symbol','Close_Price','Target',\n                'finbert_score_mean','news_count',\n                'Composite_Sentiment_Score',\n                'Composite_Sentiment_Label']].head(8).to_string())\n\nprint(\"\\nвң… STEP 2 COMPLETE!\")\nprint(\"=\"*60)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-24T08:43:27.249371Z","iopub.execute_input":"2026-04-24T08:43:27.249741Z","iopub.status.idle":"2026-04-24T08:43:28.603575Z","shell.execute_reply.started":"2026-04-24T08:43:27.249715Z","shell.execute_reply":"2026-04-24T08:43:28.602621Z"}},"outputs":[{"name":"stdout","text":"\n============================================================\n  STEP 2: Preprocessing + Merging + Sentiment Score\n============================================================\n  вҸ© Resuming from: step1_raw_data.pkl\n  вҸ© Resuming from: step1_raw_data.pkl\n\nрҹ“Ң 2A: Cleaning Stock Data...\n   Stock shape after clean : (8140, 26)\n   Missing values          : 0\n\nрҹ“Ң 2B: Cleaning News Data...\n   News shape after dropping null finbert: (52697, 17)\n\nрҹ“Ң 2C: Aggregating News by Date...\n   Daily news aggregated shape : (1087, 9)\n   