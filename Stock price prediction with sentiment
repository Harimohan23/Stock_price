05\nEpoch 53/100\n\u001b[1m78/78\u001b[0m \u001b[32mв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\u001b[0m\u001b[37m\u001b[0m \u001b[1m1s\u001b[0m 15ms/step - loss: 0.0035 - mae: 0.0429 - val_loss: 1.3357e-04 - val_mae: 0.0097 - learning_rate: 6.2500e-05\nEpoch 54/100\n\u001b[1m78/78\u001b[0m \u001b[32mв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\u001b[0m\u001b[37m\u001b[0m \u001b[1m1s\u001b[0m 15ms/step - loss: 0.0033 - mae: 0.0420 - val_loss: 1.3786e-04 - val_mae: 0.0099 - learning_rate: 6.2500e-05\nEpoch 55/100\n\u001b[1m78/78\u001b[0m \u001b[32mв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\u001b[0m\u001b[37m\u001b[0m \u001b[1m1s\u001b[0m 15ms/step - loss: 0.0041 - mae: 0.0456 - val_loss: 1.1147e-04 - val_mae: 0.0089 - learning_rate: 6.2500e-05\nEpoch 56/100\n\u001b[1m77/78\u001b[0m \u001b[32mв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\u001b[0m\u001b[37mв”Ғ\u001b[0m \u001b[1m0s\u001b[0m 13ms/step - loss: 0.0035 - mae: 0.0434\nEpoch 56: ReduceLROnPlateau reducing learning rate to 3.125000148429535e-05.\n\u001b[1m78/78\u001b[0m \u001b[32mв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\u001b[0m\u001b[37m\u001b[0m \u001b[1m1s\u001b[0m 15ms/step - loss: 0.0035 - mae: 0.0434 - val_loss: 9.5538e-05 - val_mae: 0.0082 - learning_rate: 6.2500e-05\nEpoch 56: early stopping\nRestoring model weights from the end of the best epoch: 41.\n  вҸұ  Training time: 78.1s\n  вң… Saved: step5_preds_RNN.pkl\n  вң… Saved: step5_hist_RNN.pkl\n  рҹ“Ҡ Quick Check вҶ’ RMSE: 374.04  |  Acc@5%: 22.05%\n  вң… Saved: step5_all_dl.pkl\n\n============================================================\n  вң… ALL DL MODELS TRAINED\n============================================================\n\n============================================================\n  рҹ“Ҡ DL MODEL ACCURACY RESULTS\n============================================================\n\nModel          RMSE    MAPE%   Acc@3%   Acc@5%   Acc@10%\n-------------------------------------------------------\nLSTM         311.10    17.63%   20.09%   31.27%    59.95%\nGRU          207.43    15.39%   22.73%   40.72%    70.88%\nBiLSTM       271.99    18.05%   20.82%   36.24%    62.10%\nRNN          374.04    17.73%   13.57%   22.05%    46.56%\n\n  рҹҸҶ Best DL Model (Acc@5%) : GRU вҶ’ 40.72%\n\n============================================================\n  рҹ“Ҳ PER-COMPANY ACCURACY (Acc@5%) вҖ” All DL Models\n============================================================\nCompany                  LSTM        GRU     BiLSTM        RNN\n--------------------------------------------------------------\nADANIPORTS.NS          56.76%     39.19%     20.27%     68.92%\nAPOLLOHOSP.NS           1.35%     40.54%     12.84%      2.70%\nAXISBANK.NS             8.78%     42.57%     66.22%     16.89%\nBAJAJ-AUTO.NS          18.92%     56.76%     27.70%     17.57%\nCIPLA.NS               20.95%     29.73%     20.95%     12.16%\nHCLTECH.NS              0.00%     41.22%      0.68%      0.68%\nHDFCBANK.NS            58.78%     10.81%     47.97%     25.68%\nICICIBANK.NS           72.30%     40.54%     88.51%     70.27%\nLT.NS                   9.46%     59.46%     33.11%     10.14%\nTCS.NS                 96.62%     87.16%     80.41%     17.57%\nWIPRO.NS                0.00%      0.00%      0.00%      0.00%\n--------------------------------------------------------------\nAVERAGE                31.27%     40.72%     36.24%     22.05%\n\n============================================================\n  рҹ“° COMPARISON WITH BASE PAPER\n============================================================\n  LSTM       Acc@5%: 31.27%  | рҹ“ү Below paper by 60.62%\n  GRU        Acc@5%: 40.72%  | рҹ“ү Below paper by 51.17%\n  BiLSTM     Acc@5%: 36.24%  | рҹ“ү Below paper by 55.65%\n  RNN        Acc@5%: 22.05%  | рҹ“ү Below paper by 69.84%\n\nвң… STEP 5 COMPLETE вҖ” Move to Step 6: Ensemble!\n============================================================\n","output_type":"stream"}],"execution_count":6},{"cell_type":"code","source":"# ============================================================\n# STEP 5 IMPROVED: Per-Stock Scaling + Better DL Training\n# ============================================================\n\nimport os, pickle, warnings, time\nimport numpy as np\nimport pandas as pd\nimport tensorflow as tf\nfrom tensorflow.keras.models     import Sequential, Model\nfrom tensorflow.keras.layers     import (LSTM, GRU, Dense, Dropout,\n                                          Bidirectional, SimpleRNN,\n                                          BatchNormalization, Input)\nfrom tensorflow.keras.callbacks  import (EarlyStopping, ModelCheckpoint,\n                                          ReduceLROnPlateau, CSVLogger)\nfrom tensorflow.keras.optimizers import Adam\nfrom sklearn.preprocessing       import MinMaxScaler\n\nwarnings.filterwarnings('ignore')\ntf.get_logger().setLevel('ERROR')\n\nCHECKPOINT = \"/kaggle/working/checkpoints\"\nDL_WEIGHTS = \"/kaggle/working/dl_weights_v2\"\nDL_LOGS    = \"/kaggle/working/dl_logs_v2\"\nos.makedirs(CHECKPOINT, exist_ok=True)\nos.makedirs(DL_WEIGHTS,  exist_ok=True)\nos.makedirs(DL_LOGS,     exist_ok=True)\n\ndef save_checkpoint(name, obj):\n    path = os.path.join(CHECKPOINT, f\"{name}.pkl\")\n    with open(path, 'wb') as f: pickle.dump(obj, f)\n    print(f\"  вң… Saved: {name}.pkl\")\n\ndef load_checkpoint(name):\n    path = os.path.join(CHECKPOINT, f\"{name}.pkl\")\n    if os.path.exists(path):\n        with open(path, 'rb') as f: obj = pickle.load(f)\n        print(f\"  вҸ© Resuming: {name}.pkl\")\n        return obj, True\n    return None, False\n\ndef threshold_accuracy(actual, predicted, threshold=5.0):\n    pct_error = np.abs((actual - predicted) / actual) * 100\n    return (pct_error <= threshold).mean() * 100\n\ndef rmse(actual, predicted):\n    return np.sqrt(np.mean((actual - predicted) ** 2))\n\ndef mape(actual, predicted):\n    return np.mean(np.abs((actual - predicted) / actual)) * 100\n\nprint(\"\\n\" + \"=\"*60)\nprint(\"  STEP 5 IMPROVED: Deep Learning (Per-Stock Scaling)\")\nprint(\"=\"*60)\n\n# в”Җв”Җ Load data в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nstep3, _     = load_checkpoint(\"step3_data\")\nfeature_cols = step3['feature_cols']\ntrain_df     = step3['train_df']\ntest_df      = step3['test_df']\nSEQ_LEN      = 60\nN_FEATURES   = len(feature_cols)\nBATCH_SIZE   = 32\nMAX_EPOCHS   = 150\n\n# ============================================================\n# 5A_v2: Per-Stock Scaling + Sequence Building\n# KEY FIX: Each stock gets its OWN scaler fitted on its\n#          own training data only вҶ’ no cross-stock leakage\n# ============================================================\nprint(\"\\nрҹ“Ң 5A: Building Per-Stock Scaled Sequences...\")\n\nseq_result, seq_found = load_checkpoint(\"step5v2_sequences\")\nif seq_found:\n    X_seq_train   = seq_result['X_seq_train']\n    y_seq_train   = seq_result['y_seq_train']\n    X_seq_test    = seq_result['X_seq_test']\n    y_seq_test    = seq_result['y_seq_test']\n    test_seq_meta = seq_result['test_seq_meta']\n    stock_scalers = seq_result['stock_scalers']\nelse:\n    stocks = sorted(train_df['Stock_Symbol'].unique())\n\n    X_train_list, y_train_list = [], []\n    X_test_list,  y_test_list  = [], []\n    meta_list                  = []\n    stock_scalers              = {}   # per-stock scalers for inverse transform\n\n    for stock in stocks:\n        tr = train_df[train_df['Stock_Symbol']==stock].sort_values('Date').reset_index(drop=True)\n        te = test_df[test_df['Stock_Symbol']==stock].sort_values('Date').reset_index(drop=True)\n\n        # в”Җв”Җ Per-stock scaler: fit ONLY on train в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n        sx = MinMaxScaler()\n        sy = MinMaxScaler()\n\n        tr_X = sx.fit_transform(tr[feature_cols].values)\n        tr_y = sy.fit_transform(tr['Target'].values.reshape(-1,1)).ravel()\n\n        te_X = sx.transform(te[feature_cols].values)\n        te_y = sy.transform(te['Target'].values.reshape(-1,1)).ravel()\n\n        stock_scalers[stock] = {'sx': sx, 'sy': sy}\n\n        # в”Җв”Җ Train sequences в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n        for i in range(SEQ_LEN, len(tr)):\n            X_train_list.append(tr_X[i-SEQ_LEN:i])\n            y_train_list.append(tr_y[i])\n\n        # в”Җв”Җ Test sequences (seed from train tail) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n        seed_X  = tr_X[-SEQ_LEN:]   # last 60 rows of train\n        seed_y  = tr_y[-SEQ_LEN:]\n\n        combined_X = np.vstack([seed_X, te_X])\n        combined_y = np.concatenate([seed_y, te_y])\n\n        for i in range(SEQ_LEN, len(combined_X)):\n            X_test_list.append(combined_X[i-SEQ_LEN:i])\n            y_test_list.append(combined_y[i])\n            meta_list.append({\n                'stock': stock,\n                'date' : te.iloc[i - SEQ_LEN]['Date']\n            })\n\n    X_seq_train   = np.array(X_train_list, dtype=np.float32)\n    y_seq_train   = np.array(y_train_list, dtype=np.float32)\n    X_seq_test    = np.array(X_test_list,  dtype=np.float32)\n    y_seq_test    = np.array(y_test_list,  dtype=np.float32)\n    test_seq_meta = pd.DataFrame(meta_list)\n\n    # в”Җв”Җ Shuffle train (important for DL training stability) в”Җв”Җ\n    idx = np.random.permutation(len(X_seq_train))\n    X_seq_train = X_seq_train[idx]\n    y_seq_train = y_seq_train[idx]\n\n    print(f\"   X_seq_train : {X_seq_train.shape}\")\n    print(f\"   X_seq_test  : {X_seq_test.shape}\")\n    print(f\"   Per-stock scalers: {list(stock_scalers.keys())}\")\n\n    save_checkpoint(\"step5v2_sequences\", {\n        'X_seq_train' : X_seq_train,\n        'y_seq_train' : y_seq_train,\n        'X_seq_test'  : X_seq_test,\n        'y_seq_test'  : y_seq_test,\n        'test_seq_meta': test_seq_meta,\n        'stock_scalers': stock_scalers\n    })\n\n# в”Җв”Җ Inverse transform per stock в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\ndef inverse_transform_per_stock(preds_scaled, meta_df, stock_scalers):\n    \"\"\"Convert per-stock scaled predictions back to actual prices.\"\"\"\n    preds_actual = np.zeros(len(preds_scaled))\n    for stock in meta_df['stock'].unique():\n        mask = meta_df['stock'].values == stock\n        sy   = stock_scalers[stock]['sy']\n        preds_actual[mask] = sy.inverse_transform(\n            preds_scaled[mask].reshape(-1,1)).ravel()\n    return preds_actual\n\ndef get_actual_prices_per_stock(y_scaled, meta_df, stock_scalers):\n    \"\"\"Inverse transform actual target per stock.\"\"\"\n    actual = np.zeros(len(y_scaled))\n    for stock in meta_df['stock'].unique():\n        mask = meta_df['stock'].values == stock\n        sy   = stock_scalers[stock]['sy']\n        actual[mask] = sy.inverse_transform(\n            y_scaled[mask].reshape(-1,1)).ravel()\n    return actual\n\ny_seq_test_actual = get_actual_prices_per_stock(\n    y_seq_test, test_seq_meta, stock_scalers)\n\n# ============================================================\n# 5B_v2: Improved Model Definitions\n# ============================================================\ndef build_lstm(seq_len, n_features):\n    model = Sequential([\n        LSTM(128, return_sequences=True,\n             input_shape=(seq_len, n_features)),\n        BatchNormalization(),\n        Dropout(0.3),\n        LSTM(64, return_sequences=True),\n        BatchNormalization(),\n        Dropout(0.2),\n        LSTM(32, return_sequences=False),\n        BatchNormalization(),\n        Dropout(0.1),\n        Dense(64, activation='relu'),\n        Dropout(0.1),\n        Dense(32, activation='relu'),\n        Dense(1)\n    ], name='LSTM_v2')\n    model.compile(optimizer=Adam(0.001), loss='huber',\n                  metrics=['mae'])\n    return model\n\ndef build_gru(seq_len, n_features):\n    model = Sequential([\n        GRU(128, return_sequences=True,\n            input_shape=(seq_len, n_features)),\n        BatchNormalization(),\n        Dropout(0.3),\n        GRU(64, return_sequences=True),\n        BatchNormalization(),\n        Dropout(0.2),\n        GRU(32, return_sequences=False),\n        BatchNormalization(),\n        Dropout(0.1),\n        Dense(64, activation='relu'),\n        Dropout(0.1),\n        Dense(32, activation='relu'),\n        Dense(1)\n    ], name='GRU_v2')\n    model.compile(optimizer=Adam(0.001), loss='huber',\n                  metrics=['mae'])\n    return model\n\ndef build_bilstm(seq_len, n_features):\n    model = Sequential([\n        Bidirectional(LSTM(64, return_sequences=True),\n                      input_shape=(seq_len, n_features)),\n        BatchNormalization(),\n        Dropout(0.3),\n        Bidirectional(LSTM(32, return_sequences=False)),\n        BatchNormalization(),\n        Dropout(0.2),\n        Dense(64, activation='relu'),\n        Dropout(0.1),\n        Dense(32, activation='relu'),\n        Dense(1)\n    ], name='BiLSTM_v2')\n    model.compile(optimizer=Adam(0.001), loss='huber',\n                  metrics=['mae'])\n    return model\n\ndef build_rnn(seq_len, n_features):\n    model = Sequential([\n        SimpleRNN(128, return_sequences=True,\n                  input_shape=(seq_len, n_features)),\n        BatchNormalization(),\n        Dropout(0.3),\n        SimpleRNN(64, return_sequences=False),\n        BatchNormalization(),\n        Dropout(0.2),\n        Dense(64, activation='relu'),\n        Dropout(0.1),\n        Dense(32, activation='relu'),\n        Dense(1)\n    ], name='RNN_v2')\n    model.compile(optimizer=Adam(0.001), loss='huber',\n                  metrics=['mae'])\n    return model\n\nmodel_builders = {\n    'LSTM'  : build_lstm,\n    'GRU'   : build_gru,\n    'BiLSTM': build_bilstm,\n    'RNN'   : build_rnn,\n}\n\n# ============================================================\n# 5C_v2: Train with Full Resume Support\n# ============================================================\nprint(\"\\nрҹ“Ң 5C: Training Improved DL Models...\")\n\ndl_predictions = {}\ndl_histories   = {}\n\nfor model_name, builder in model_builders.items():\n\n    print(f\"\\n{'='*50}\")\n    print(f\"  рҹ”„ {model_name} (Improved)\")\n    print(f\"{'='*50}\")\n\n    pred_ck  = f\"step5v2_preds_{model_name}\"\n    hist_ck  = f\"step5v2_hist_{model_name}\"\n    wt_path  = os.path.join(DL_WEIGHTS, f\"{model_name}_best.weights.h5\")\n    log_path = os.path.join(DL_LOGS,    f\"{model_name}_log.csv\")\n\n    # в”Җв”Җ Already done вҶ’ skip в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    preds_saved, pred_found = load_checkpoint(pred_ck)\n    if pred_found:\n        dl_predictions[model_name] = preds_saved\n        hist_saved, _ = load_checkpoint(hist_ck)\n        if hist_saved:\n            dl_histories[model_name] = hist_saved\n        acc = threshold_accuracy(y_seq_test_actual, preds_saved, 5)\n        print(f\"  вҸ© Loaded вҖ” Acc@5%: {acc:.2f}%\")\n        continue\n\n    # в”Җв”Җ Build model в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    model = builder(SEQ_LEN, N_FEATURES)\n    model.summary()\n\n    # в”Җв”Җ Resume weights if interrupted в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    if os.path.exists(wt_path):\n        print(f\"  вҡЎ Resuming weights: {wt_path}\")\n        model.load_weights(wt_path)\n\n    callbacks = [\n        EarlyStopping(\n            monitor              = 'val_loss',\n            patience             = 20,\n            restore_best_weights = True,\n            verbose              = 1\n        ),\n        ModelCheckpoint(\n            filepath          = wt_path,\n            monitor           = 'val_loss',\n            save_best_only    = True,\n            save_weights_only = True,\n            verbose           = 0\n        ),\n        ReduceLROnPlateau(\n            monitor  = 'val_loss',\n            factor   = 0.5,\n            patience = 8,\n            min_lr   = 1e-7,\n            verbose  = 1\n        ),\n        CSVLogger(log_path, append=True)\n    ]\n\n    t0 = time.time()\n    history = model.fit(\n        X_seq_train, y_seq_train,\n        validation_split = 0.15,\n        epochs           = MAX_EPOCHS,\n        batch_size       = BATCH_SIZE,\n        callbacks        = callbacks,\n        verbose          = 1\n    )\n    elapsed = time.time() - t0\n    print(f\"  вҸұ  Training time: {elapsed:.1f}s\")\n\n    if os.path.exists(wt_path):\n        model.load_weights(wt_path)\n\n    # в”Җв”Җ Predict & inverse transform per stock в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    preds_scaled = model.predict(X_seq_test, verbose=0).ravel()\n    preds_actual = inverse_transform_per_stock(\n                       preds_scaled, test_seq_meta, stock_scalers)\n\n    dl_predictions[model_name] = preds_actual\n    dl_histories[model_name]   = history.history\n\n    save_checkpoint(pred_ck, preds_actual)\n    save_checkpoint(hist_ck, history.history)\n\n    acc = threshold_accuracy(y_seq_test_actual, preds_actual, 5)\n    r   = rmse(y_seq_test_actual, preds_actual)\n    print(f\"  рҹ“Ҡ Quick Check вҶ’ RMSE: {r:.2f}  |  Acc@5%: {acc:.2f}%\")\n\n# в”Җв”Җ Save all в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nresult_dl, found_dl = load_checkpoint(\"step5v2_all_dl\")\nif not found_dl:\n    save_checkpoint(\"step5v2_all_dl\", {\n        'dl_predictions'   : dl_predictions,\n        'y_seq_test_actual': y_seq_test_actual,\n        'test_seq_meta'    : test_seq_meta,\n        'stock_scalers'    : stock_scalers\n    })\n\n# ============================================================\n# RESULTS\n# ============================================================\nprint(\"\\n\" + \"=\"*60)\nprint(\"  рҹ“Ҡ IMPROVED DL RESULTS vs ORIGINAL\")\nprint(\"=\"*60)\n\n# Original results for comparison\noriginal = {'LSTM':36.55,'GRU':41.52,'BiLSTM':34.40,'RNN':41.52}\n\nprint(f\"\\n{'Model':<10} {'RMSE':>8} {'MAPE%':>8} \"\n      f\"{'Acc@3%':>8} {'Acc@5%':>8} {'Acc@10%':>9} {'vs Old':>8}\")\nprint(\"-\"*65)\n\ndl_overall = {}\nfor mn, preds in dl_predictions.items():\n    r   = rmse(y_seq_test_actual, preds)\n    mp  = mape(y_seq_test_actual, preds)\n    a3  = threshold_accuracy(y_seq_test_actual, preds, 3)\n    a5  = threshold_accuracy(y_seq_test_actual, preds, 5)\n    a10 = threshold_accuracy(y_seq_test_actual, preds, 10)\n    dl_overall[mn] = {'RMSE':r,'MAPE':mp,'Acc@3':a3,'Acc@5':a5,'Acc@10':a10}\n    old  = original.get(mn, 0)\n    diff = a5 - old\n    sign = \"вң… +\" if diff >= 0 else \"рҹ“ү \"\n    print(f\"{mn:<10} {r:>8.2f} {mp:>8.2f}% \"\n          f\"{a3:>7.2f}% {a5:>7.2f}% {a10:>8.2f}%  \"\n          f\"{sign}{abs(diff):.2f}%\")\n\nbest_dl = max(dl_overall, key=lambda x: dl_overall[x]['Acc@5'])\nprint(f\"\\n  рҹҸҶ Best DL (Acc@5%): {best_dl} вҶ’ \"\n      f\"{dl_overall[best_dl]['Acc@5']:.2f}%\")\n\nprint(\"\\n\" + \"=\"*60)\nprint(\"  рҹ“Ҳ PER-COMPANY ACCURACY (Acc@5%)\")\nprint(\"=\"*60)\n\nstocks = sorted(test_seq_meta['stock'].unique())\nheader = f\"{'Company':<18}\"\nfor mn in dl_predictions.keys():\n    header += f\" {mn:>10}\"\nprint(header)\nprint(\"-\" * (18 + 11 * len(dl_predictions)))\n\nfor stock in stocks:\n    mask     = test_seq_meta['stock'].values == stock\n    actual_s = y_seq_test_actual[mask]\n    row = f\"{stock:<18}\"\n    for mn, preds in dl_predictions.items():\n        acc = threshold_accuracy(actual_s, preds[mask], 5)\n        row += f\" {acc:>9.2f}%\"\n    print(row)\n\nprint(\"-\" * (18 + 11 * len(dl_predictions)))\navg_row = f\"{'AVERAGE':<18}\"\nfor mn in dl_predictions.keys():\n    accs = [threshold_accuracy(\n                y_seq_test_actual[test_seq_meta['stock'].values==s],\n                dl_predictions[mn][test_seq_meta['stock'].values==s], 5)\n            for s in stocks]\n    avg_row += f\" {np.mean(accs):>9.2f}%\"\nprint(avg_row)\n\nprint(\"\\n\" + \"=\"*60)\nprint(\"  рҹ“° vs BASE PAPER (91.89%)\")\nprint(\"=\"*60)\nfor mn, res in dl_overall.items():\n    gap    = res['Acc@5'] - 91.89\n    status = \"вң… BEATS\" if gap >= 0 else \"рҹ“ү Below\"\n    print(f\"  {mn:<10} {res['Acc@5']:.2f}%  {status} paper by {abs(gap):.2f}%\")\n\nprint(\"\\nвң… STEP 5 IMPROVED COMPLETE вҶ’ Move to Step 6: Ensemble!\")\nprint(\"=\"*60)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-24T08:51:13.478794Z","iopub.execute_input":"2026-04-24T08:51:13.479575Z","iopub.status.idle":"2026-04-24T09:08:25.775042Z","shell.execute_reply.started":"2026-04-24T08:51:13.479544Z","shell.execute_reply":"2026-04-24T09:08:25.774191Z"}},"outputs":[{"name":"stdout","text":"\n============================================================\n  STEP 5 IMPROVED: Deep Learning (Per-Stock Scaling)\n============================================================\n  вҸ© Resuming: step3_data.pkl\n\nрҹ“Ң 5A: Building Per-Stock Scaled Sequences...\n   X_seq_train : (5819, 60, 68)\n   X_seq_test  : (1628, 60, 68)\n   Per-stock scalers: ['ADANIPORTS.NS', 'APOLLOHOSP.NS', 'AXISBANK.NS', 'BAJAJ-AUTO.NS', 'CIPLA.NS', 'HCLTECH.NS', 'HDFCBANK.NS', 'ICICIBANK.NS', 'LT.NS', 'TCS.NS', 'WIPRO.NS']\n  вң… Saved: step5v2_sequences.pkl\n\nрҹ“Ң 5C: Training Improved DL Models...\n\n==================================================\n  рҹ”„ LSTM (Improved)\n==================================================\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"\u001b[1mModel: \"LSTM_v2\"\u001b[0m\n","text/html":"<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\"><span style=\"font-weight: bold\">Model: \"LSTM_v2\"</span>\n</pre>\n"},"metadata":{}},{"o