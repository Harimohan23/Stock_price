aler_y,\n     train_df, test_df) = (data['X_train'], data['X_test'],\n                           data['y_train'], data['y_test'],\n                           data['X_train_raw'], data['X_test_raw'],\n                           data['feature_cols'], data['scaler_X'],\n                           data['scaler_y'], data['train_df'],\n                           data['test_df'])\nelse:\n    # в”Җв”Җ Load Step 2 output в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    final_df, _ = load_checkpoint(\"step2_final_df\")\n\n    df = final_df.copy()\n    df = df.sort_values(['Stock_Symbol', 'Date']).reset_index(drop=True)\n\n    # ============================================================\n    # 3A: Encode Stock_Symbol\n    # ============================================================\n    print(\"\\nрҹ“Ң 3A: Encoding Stock_Symbol...\")\n    le = LabelEncoder()\n    df['Stock_Symbol_Enc'] = le.fit_transform(df['Stock_Symbol'])\n    print(f\"   Symbols вҶ’ Encoded: {dict(zip(le.classes_, le.transform(le.classes_)))}\")\n\n    # ============================================================\n    # 3B: Lag Features (per stock group)\n    # Previous 1,2,3 days of key features\n    # ============================================================\n    print(\"\\nрҹ“Ң 3B: Creating Lag Features...\")\n\n    lag_cols = ['Close_Price', 'Volume', 'RSI_14', 'ATR_14',\n                'Composite_Sentiment_Score', 'finbert_score_mean',\n                'Daily_Return_Pct', 'Volatility_20D']\n\n    for col in lag_cols:\n        for lag in [1, 2, 3]:\n            df[f'{col}_lag{lag}'] = df.groupby('Stock_Symbol')[col].shift(lag)\n\n    print(f\"   Lag features created : {len(lag_cols) * 3} columns\")\n\n    # ============================================================\n    # 3C: Rolling Window Features (per stock group)\n    # ============================================================\n    print(\"\\nрҹ“Ң 3C: Creating Rolling Features...\")\n\n    df['Return_Rolling3']       = df.groupby('Stock_Symbol')['Daily_Return_Pct'].transform(\n                                      lambda x: x.rolling(3).mean())\n    df['Sentiment_Rolling3']    = df.groupby('Stock_Symbol')['Composite_Sentiment_Score'].transform(\n                                      lambda x: x.rolling(3).mean())\n    df['Volatility_Rolling3']   = df.groupby('Stock_Symbol')['Volatility_20D'].transform(\n                                      lambda x: x.rolling(3).mean())\n    df['Volume_Rolling3']       = df.groupby('Stock_Symbol')['Volume'].transform(\n                                      lambda x: x.rolling(3).mean())\n    df['RSI_Rolling3']          = df.groupby('Stock_Symbol')['RSI_14'].transform(\n                                      lambda x: x.rolling(3).mean())\n\n    # Price momentum: Close vs SMA ratios\n    df['Price_vs_SMA7']  = df['Close_Price'] / df['SMA_7']\n    df['Price_vs_SMA14'] = df['Close_Price'] / df['SMA_14']\n    df['Price_vs_SMA50'] = df['Close_Price'] / df['SMA_50']\n\n    # High-Low spread\n    df['HL_Spread']      = (df['High_Price'] - df['Low_Price']) / df['Close_Price']\n\n    # Sentiment momentum\n    df['Sentiment_Momentum'] = df['Composite_Sentiment_Score'] - df.groupby(\n                                    'Stock_Symbol')['Composite_Sentiment_Score'].shift(1)\n\n    # News volume momentum\n    df['News_Count_lag1']    = df.groupby('Stock_Symbol')['news_count'].shift(1)\n    df['News_Count_lag1']    = df['News_Count_lag1'].fillna(0)\n\n    print(f\"   Rolling features created : 11 columns\")\n\n    # ============================================================\n    # 3D: Drop rows with NaN from lag/rolling (first 3 rows per stock)\n    # ============================================================\n    print(\"\\nрҹ“Ң 3D: Dropping NaN rows from lag features...\")\n    before = len(df)\n    df = df.dropna().reset_index(drop=True)\n    after = len(df)\n    print(f\"   Rows before : {before}\")\n    print(f\"   Rows after  : {after}\")\n    print(f\"   Rows dropped: {before - after}\")\n\n    # ============================================================\n    # 3E: Define Feature Columns\n    # ============================================================\n    print(\"\\nрҹ“Ң 3E: Defining Feature Set...\")\n\n    # Drop non-feature columns\n    drop_cols = ['Date', 'Stock_Symbol', 'Target',\n                 'Composite_Sentiment_Label', 'finbert_label'\n                 if 'finbert_label' in df.columns else 'none']\n    drop_cols = [c for c in drop_cols if c in df.columns]\n\n    feature_cols = [c for c in df.columns if c not in drop_cols]\n    print(f\"   Total features : {len(feature_cols)}\")\n    print(f\"   Features list  :\")\n    for i, f in enumerate(feature_cols):\n        print(f\"      {i+1:02d}. {f}\")\n\n    # ============================================================\n    # 3F: Chronological Train/Test Split (80/20)\n    # в”Җв”Җ MUST be time-based, not random, for time series!\n    # ============================================================\n    print(\"\\nрҹ“Ң 3F: Chronological Train/Test Split (80/20)...\")\n\n    df = df.sort_values('Date').reset_index(drop=True)\n    split_idx = int(len(df) * 0.80)\n    split_date = df.iloc[split_idx]['Date']\n\n    train_df = df[df['Date'] <  split_date].reset_index(drop=True)\n    test_df  = df[df['Date'] >= split_date].reset_index(drop=True)\n\n    print(f\"   Split date      : {split_date.date()}\")\n    print(f\"   Train rows      : {len(train_df)}  ({len(train_df)/len(df)*100:.1f}%)\")\n    print(f\"   Test rows       : {len(test_df)}   ({len(test_df)/len(df)*100:.1f}%)\")\n    print(f\"   Train date range: {train_df['Date'].min().date()} вҶ’ {train_df['Date'].max().date()}\")\n    print(f\"   Test  date range: {test_df['Date'].min().date()} вҶ’ {test_df['Date'].max().date()}\")\n\n    # ============================================================\n    # 3G: Scale Features\n    # в”Җв”Җ Fit scaler ONLY on train, apply to both\n    # ============================================================\n    print(\"\\nрҹ“Ң 3G: Scaling Features (fit on train only)...\")\n\n    X_train_raw = train_df[feature_cols].values\n    X_test_raw  = test_df[feature_cols].values\n    y_train_raw = train_df['Target'].values.reshape(-1, 1)\n    y_test_raw  = test_df['Target'].values.reshape(-1, 1)\n\n    scaler_X = MinMaxScaler()\n    scaler_y = MinMaxScaler()\n\n    X_train = scaler_X.fit_transform(X_train_raw)\n    X_test  = scaler_X.transform(X_test_raw)\n\n    y_train = scaler_y.fit_transform(y_train_raw).ravel()\n    y_test  = scaler_y.transform(y_test_raw).ravel()\n\n    print(f\"   X_train shape : {X_train.shape}\")\n    print(f\"   X_test shape  : {X_test.shape}\")\n    print(f\"   y_train range : {y_train.min():.4f} вҶ’ {y_train.max():.4f}\")\n    print(f\"   y_test range  : {y_test.min():.4f} вҶ’ {y_test.max():.4f}\")\n\n    # ============================================================\n    # 3H: Save Everything\n    # ============================================================\n    data = {\n        'X_train': X_train, 'X_test': X_test,\n        'y_train': y_train, 'y_test': y_test,\n        'X_train_raw': X_train_raw, 'X_test_raw': X_test_raw,\n        'feature_cols': feature_cols,\n        'scaler_X': scaler_X, 'scaler_y': scaler_y,\n        'train_df': train_df, 'test_df': test_df\n    }\n    save_checkpoint(\"step3_data\", data)\n\n# ============================================================\n# вң… VERIFICATION\n# ============================================================\nprint(\"\\n\" + \"=\"*60)\nprint(\"  STEP 3 VERIFICATION\")\nprint(\"=\"*60)\n\nprint(f\"\\nрҹ“җ X_train shape    : {X_train.shape}\")\nprint(f\"рҹ“җ X_test  shape    : {X_test.shape}\")\nprint(f\"рҹҺҜ y_train shape    : {y_train.shape}\")\nprint(f\"рҹҺҜ y_test  shape    : {y_test.shape}\")\nprint(f\"рҹ”ў Total features   : {len(feature_cols)}\")\nprint(f\"рҹ“… Train period     : {train_df['Date'].min().date()} вҶ’ {train_df['Date'].max().date()}\")\nprint(f\"рҹ“… Test  period     : {test_df['Date'].min().date()} вҶ’ {test_df['Date'].max().date()}\")\n\n# Sanity check: no data leakage\nassert train_df['Date'].max() < test_df['Date'].min(), \"вқҢ DATA LEAKAGE DETECTED!\"\nprint(f\"\\nвң… No data leakage confirmed (train ends before test starts)\")\n\n# Sanity check: shapes\nassert X_train.shape[1] == X_test.shape[1], \"вқҢ Feature mismatch!\"\nprint(f\"вң… Feature count consistent across train/test\")\n\n# Check target distribution\ny_train_actual = scaler_y.inverse_transform(y_train.reshape(-1,1)).ravel()\ny_test_actual  = scaler_y.inverse_transform(y_test.reshape(-1,1)).ravel()\nprint(f\"\\nрҹ“Ҡ Target (actual price) stats:\")\nprint(f\"   Train вҶ’ min: {y_train_actual.min():.2f}, max: {y_train_actual.max():.2f}, mean: {y_train_actual.mean():.2f}\")\nprint(f\"   Test  вҶ’ min: {y_test_actual.min():.2f}, max: {y_test_actual.max():.2f}, mean: {y_test_actual.mean():.2f}\")\n\nprint(f\"\\nрҹ“Ӣ Stocks in Train : {sorted(train_df['Stock_Symbol'].unique())}\")\nprint(f\"рҹ“Ӣ Stocks in Test  : {sorted(test_df['Stock_Symbol'].unique())}\")\n\nprint(\"\\nвң… STEP 3 COMPLETE!\")\nprint(\"=\"*60)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-24T08:43:28.604780Z","iopub.execute_input":"2026-04-24T08:43:28.605504Z","iopub.status.idle":"2026-04-24T08:43:28.753210Z","shell.execute_reply.started":"2026-04-24T08:43:28.605478Z","shell.execute_reply":"2026-04-24T08:43:28.752241Z"}},"outputs":[{"name":"stdout","text":"\n============================================================\n  STEP 3: Feature Engineering + Train/Test Split\n============================================================\n  вҸ© Resuming from: step2_final_df.pkl\n\nрҹ“Ң 3A: Encoding Stock_Symbol...\n   Symbols вҶ’ Encoded: {'ADANIPORTS.NS': np.int64(0), 'APOLLOHOSP.NS': np.int64(1), 'AXISBANK.NS': np.int64(2), 'BAJAJ-AUTO.NS': np.int64(3), 'CIPLA.NS': np.int64(4), 'HCLTECH.NS': np.int