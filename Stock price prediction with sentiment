1%     рҹ“ү -57.68%\n  ML50+DL50                         9.15%     рҹ“ү -82.74%\n  GradientBoosting (ML)             8.17%     рҹ“ү -83.72%\n  OptWeights_ML                     8.17%     рҹ“ү -83.72%\n\n============================================================\n  рҹ“Ҳ PER-COMPANY: Best DL Ensemble vs Paper\n============================================================\n\n  Company                DL Ens    ML+DL    Paper\n  ----------------------------------------------\n  ADANIPORTS.NS          30.41%   12.84%   98.78%\n  APOLLOHOSP.NS           2.03%    0.68%   89.02%\n  AXISBANK.NS             3.38%   12.84%   81.71%\n  BAJAJ-AUTO.NS           0.00%    6.08%   79.27%\n  CIPLA.NS                2.03%    8.11%   90.24%\n  HCLTECH.NS             43.92%   12.84%   95.12%\n  HDFCBANK.NS            88.51%    9.46%   93.90%\n  ICICIBANK.NS           53.38%   21.62%   95.12%\n  LT.NS                   8.78%    6.08%   97.56%\n  TCS.NS                 89.86%    8.11%   99.32%\n  WIPRO.NS               54.05%    2.03%   98.70%\n  ----------------------------------------------\n  AVERAGE                34.21%    9.15%   92.61%\n  вң… Saved: step5ps_final.pkl\n\nвң… PER-STOCK DL + ENSEMBLE COMPLETE!\n============================================================\n","output_type":"stream"}],"execution_count":10},{"cell_type":"code","source":"# ============================================================\n# PER-STOCK DL FIXED: Correct alignment + proper ensemble\n# ============================================================\n\nimport os, pickle, warnings, time, itertools\nimport numpy as np\nimport pandas as pd\nimport tensorflow as tf\nfrom tensorflow.keras.models    import Sequential\nfrom tensorflow.keras.layers    import (LSTM, GRU, Dense, Dropout,\n                                         Bidirectional, SimpleRNN,\n                                         BatchNormalization)\nfrom tensorflow.keras.callbacks import (EarlyStopping, ModelCheckpoint,\n                                         ReduceLROnPlateau)\nfrom tensorflow.keras.optimizers import Adam\nfrom sklearn.preprocessing      import MinMaxScaler\n\nwarnings.filterwarnings('ignore')\ntf.get_logger().setLevel('ERROR')\n\nCHECKPOINT = \"/kaggle/working/checkpoints\"\nPS_WEIGHTS = \"/kaggle/working/per_stock_weights\"\nos.makedirs(CHECKPOINT, exist_ok=True)\nos.makedirs(PS_WEIGHTS,  exist_ok=True)\n\ndef save_checkpoint(name, obj):\n    path = os.path.join(CHECKPOINT, f\"{name}.pkl\")\n    with open(path, 'wb') as f: pickle.dump(obj, f)\n    print(f\"  вң… Saved: {name}.pkl\")\n\ndef load_checkpoint(name):\n    path = os.path.join(CHECKPOINT, f\"{name}.pkl\")\n    if os.path.exists(path):\n        with open(path, 'rb') as f: obj = pickle.load(f)\n        print(f\"  вҸ© Resuming: {name}.pkl\")\n        return obj, True\n    return None, False\n\ndef threshold_accuracy(actual, predicted, threshold=5.0):\n    pct_error = np.abs((actual - predicted) / actual) * 100\n    return (pct_error <= threshold).mean() * 100\n\ndef rmse(actual, predicted):\n    return np.sqrt(np.mean((actual - predicted) ** 2))\n\ndef mape(actual, predicted):\n    return np.mean(np.abs((actual - predicted) / actual)) * 100\n\nprint(\"\\n\" + \"=\"*60)\nprint(\"  PER-STOCK DL FIXED: Correct Assembly\")\nprint(\"=\"*60)\n\n# в”Җв”Җ Load data в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nstep3, _     = load_checkpoint(\"step3_data\")\nfeature_cols = step3['feature_cols']\ntrain_df     = step3['train_df']\ntest_df      = step3['test_df']    # already sorted by Date in step3\n\nml_data, _   = load_checkpoint(\"step4_all_ml\")\nml_preds     = ml_data['ml_predictions']\ny_actual     = ml_data['y_test_actual']  # вҶҗ SINGLE ground truth\n\n# test_df is the reference вҖ” all predictions must align to this\ntest_df_ref  = test_df.copy().reset_index(drop=True)\ntest_df_ref['row_idx'] = test_df_ref.index\n\nprint(f\"   test_df rows       : {len(test_df_ref)}\")\nprint(f\"   y_actual rows      : {len(y_actual)}\")\nprint(f\"   test_df date range : {test_df_ref['Date'].min().date()} \"\n      f\"вҶ’ {test_df_ref['Date'].max().date()}\")\n\n# Verify ML baseline on correct y_actual\ngb_acc = threshold_accuracy(y_actual, ml_preds['GradientBoosting'], 5)\nprint(f\"\\n   вң… GB baseline check: {gb_acc:.2f}% \"\n      f\"(should be ~95.15%)\")\n\nSEQ_LEN    = 60\nN_FEATURES = len(feature_cols)\nstocks     = sorted(test_df_ref['Stock_Symbol'].unique())\n\n# ============================================================\n# MODEL BUILDERS\n# ============================================================\ndef build_lstm(s, n):\n    m = Sequential([\n        LSTM(64, return_sequences=True, input_shape=(s,n)),\n        BatchNormalization(), Dropout(0.2),\n        LSTM(32), BatchNormalization(), Dropout(0.2),\n        Dense(32, activation='relu'), Dropout(0.1), Dense(1)\n    ], name='LSTM')\n    m.compile(optimizer=Adam(0.001), loss='huber', metrics=['mae'])\n    return m\n\ndef build_gru(s, n):\n    m = Sequential([\n        GRU(64, return_sequences=True, input_shape=(s,n)),\n        BatchNormalization(), Dropout(0.2),\n        GRU(32), BatchNormalization(), Dropout(0.2),\n        Dense(32, activation='relu'), Dropout(0.1), Dense(1)\n    ], name='GRU')\n    m.compile(optimizer=Adam(0.001), loss='huber', metrics=['mae'])\n    return m\n\ndef build_bilstm(s, n):\n    m = Sequential([\n        Bidirectional(LSTM(32, return_sequences=True),\n                      input_shape=(s,n)),\n        BatchNormalization(), Dropout(0.2),\n        Bidirectional(LSTM(16)),\n        BatchNormalization(), Dropout(0.2),\n        Dense(32, activation='relu'), Dropout(0.1), Dense(1)\n    ], name='BiLSTM')\n    m.compile(optimizer=Adam(0.001), loss='huber', metrics=['mae'])\n    return m\n\ndef build_rnn(s, n):\n    m = Sequential([\n        SimpleRNN(64, return_sequences=True, input_shape=(s,n)),\n        BatchNormalization(), Dropout(0.2),\n        SimpleRNN(32), BatchNormalization(), Dropout(0.2),\n        Dense(32, activation='relu'), Dropout(0.1), Dense(1)\n    ], name='RNN')\n    m.compile(optimizer=Adam(0.001), loss='huber', metrics=['mae'])\n    return m\n\nbuilders = {'LSTM':build_lstm, 'GRU':build_gru,\n            'BiLSTM':build_bilstm, 'RNN':build_rnn}\n\n# ============================================================\n# TRAIN PER STOCK вҖ” save (predictions, row_indices)\n# ============================================================\nprint(\"\\nрҹ“Ң Training Per-Stock DL Models...\")\n\n# Storage: for each model, full-length array aligned to test_df_ref\ndl_full = {mn: np.full(len(test_df_ref), np.nan)\n           for mn in builders}\n\nfor stock in stocks:\n\n    print(f\"\\n  {'в”Җ'*45}\")\n    print(f\"  рҹ“Ҳ {stock}\")\n\n    # в”Җв”Җ Get this stock's rows in test_df_ref в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    stock_mask  = test_df_ref['Stock_Symbol'].values == stock\n    row_indices = np.where(stock_mask)[0]   # positions in test_df_ref\n\n    # в”Җв”Җ Get train/test for this stock в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    tr = train_df[train_df['Stock_Symbol']==stock]\\\n             .sort_values('Date').reset_index(drop=True)\n    te = test_df_ref[test_df_ref['Stock_Symbol']==stock]\\\n             .sort_values('Date').reset_index(drop=True)\n\n    # в”Җв”Җ Per-stock scaler в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    sx = MinMaxScaler()\n    sy = MinMaxScaler()\n    tr_X = sx.fit_transform(tr[feature_cols].values)\n    tr_y = sy.fit_transform(\n               tr['Target'].values.reshape(-1,1)).ravel()\n    te_X = sx.transform(te[feature_cols].values)\n    te_y = sy.transform(\n               te['Target'].values.reshape(-1,1)).ravel()\n\n    # actual prices for this stock (ground truth)\n    actual_stock = sy.inverse_transform(\n                       te_y.reshape(-1,1)).ravel()\n\n    # в”Җв”Җ Verify actual_stock matches y_actual at row_indices в”Җв”Җ\n    y_actual_stock = y_actual[row_indices]\n    match_pct = np.mean(\n        np.abs(actual_stock - y_actual_stock) /\n        (y_actual_stock + 1e-8)) * 100\n    print(f\"  Actual price match vs global: \"\n          f\"mean diff = {match_pct:.4f}%\"\n          f\" {'вң…' if match_pct < 1 else 'вҡ пёҸ CHECK'}\")\n\n    # в”Җв”Җ Build sequences в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    X_tr, y_tr = [], []\n    for i in range(SEQ_LEN, len(tr)):\n        X_tr.append(tr_X[i-SEQ_LEN:i])\n        y_tr.append(tr_y[i])\n    X_tr = np.array(X_tr, dtype=np.float32)\n    y_tr = np.array(y_tr, dtype=np.float32)\n\n    # Test: seed with last SEQ_LEN train rows\n    combined_X = np.vstack([tr_X[-SEQ_LEN:], te_X])\n    combined_y = np.concatenate([tr_y[-SEQ_LEN:], te_y])\n    X_te, y_te = [], []\n    for i in range(SEQ_LEN, len(combined_X)):\n        X_te.append(combined_X[i-SEQ_LEN:i])\n        y_te.append(combined_y[i])\n    X_te = np.array(X_te, dtype=np.float32)\n    y_te = np.array(y_te, dtype=np.float32)\n\n    assert len(X_te) == len(te), \\\n        f\"Sequence length {len(X_te)} != test rows {len(te)}\"\n\n    # в”Җв”Җ Train each model в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    for mn, builder in builders.items():\n\n        ck_name = f\"psfix_{stock.replace('.','_')}_{mn}\"\n        saved, found = load_checkpoint(ck_name)\n\n        if found:\n            preds_actual = saved\n        else:\n            model   = builder(SEQ_LEN, N_FEATURES)\n            wt_path = os.path.join(\n                PS_WEIGHTS,\n                f\"fix_{stock.replace('.','_')}_{mn}.weights.h5\"\n            )\n            if os.path.exists(wt_path):\n                model.load_weights(wt_path)\n\n            cbs = [\n                EarlyStopping(monitor='val_loss', patience=20,\n                              restore_best_weights=True,\n                              verbose=0),\n                ModelCheckpoint(wt_path, monitor='val_loss',\n                                save_best_only=True,\n                                save_weights_only=True,\n                                verbose=0),\n                ReduceLROnPlateau(monitor='val_loss', factor=0.5,\n                                  patience=8, min_lr=1e-7,\n                                  verbose=0)\n            ]\n            t0 = time.time()\n            model.fit(X_tr, y_tr,\n                      validation_split=0.15,\n                      epochs=150, batch_size=32,\n                      callbacks=cbs, verbose=0)\n            elapsed = time.time() - t0\n\n            preds_sc     = model.predict(X_te, verbose=0).ravel()\n            preds_actual = sy.inverse_transform(\n                               preds_sc.reshape(-1,1)).ravel()\n            save_checkpoint(ck_name, preds_actual)\n            tf.keras.backend.clear_session()\n\n        # в”Җв”Җ Evaluate against global y_actual в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n        acc_local  = threshold_accuracy(actual_stock, preds_actual, 5)\n        acc_global = threshold_accuracy(\n                         y_actual_stock, preds_actual, 5)\n\n        print(f\"  {mn:<8} \"\n              f\"local_acc:{acc_local:>6.2f}%  \"\n              f\"global_acc:{acc_global:>6.2f}%\"\n              f\"  {'вң…' if abs(acc_local-acc_global)<1 else 'вҡ пёҸ'}\")\n\n        # в”Җв”Җ Place into full array at correct positions в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n        # Sort te by Date to ensure ordering matches row_indices\n        te_sorted   = te.sort_values('Date').reset_index(drop=True)\n        sort_order  = te_sorted.index.values\n        preds_sorted = preds_actual[sort_order]\n\n        # row_indices are positions in test_df_ref sorted by Date\n        # te_sorted also sorted by Date вҶ’ direct alignment\n        ri_sorted   = row_indices[\n            np.argsort(\n                test_df_ref.loc[row_indices,'Date'].values\n            )\n        ]\n        for k, ri in enumerate(ri_sorted):\n            dl_full[mn][ri] = preds_sorted[k]\n\n# ============================================================\n# VERIFY ASSEMBLY\n# ============================================================\nprint(\"\\n\\nрҹ“Ң Verifying Assembly...\")\nfor mn in builders:\n    nan_count = np.isnan(dl_full[mn]).sum()\n    print(f\"   {mn}: NaN count = {nan_count}\", end=\"\")\n    if nan_count > 0:\n        # Fill NaN with GradientBoosting (safe fallback)\n        nan_mask = np.isnan(dl_full[mn])\n        dl_full[mn][nan_mask] = ml_preds['GradientBoosting'][nan_mask]\n        print(f\" вҶ’ filled with GB\", end=\"\")\n    acc = threshold_accuracy(y_actual, dl_full[mn], 5)\n    print(f\"  |  Acc@5% vs global: {acc:.2f}%\")\n\n# ============================================================\n# PER-STOCK ACCURACY TABLE\n# ============================================================\nprint(\"\\n\" + \"=\"*60)\nprint(\"  рҹ“Ҡ PER-STOCK DL RESULTS (vs global y_actual)\")\nprint(\"=\"*60)\n\nprint(f\"\\n  {'Stock':<20} {'LSTM':>8} {'GRU':>8} \"\n      f\"{'BiLSTM':>8} {'RNN':>8} {'Best':>8}\")\nprint(\"  \" + \"-\"*65)\n\nps_accs = {mn:[] for mn in builders}\nfor stock in stocks:\n    mask = test_df_ref['Stock_Symbol'].values == stock\n    row  = f\"  {stock:<20}\"\n    best = 0\n    for mn in builders:\n        a = threshold_accuracy(y_actual[mask], dl_full[mn][mask], 5)\n        ps_accs[mn].append(a)\n        row += f\" {a:>7.2f}%\"\n        best = max(best, a)\n    row += f\" {best:>7.2f}%\"\n    print(row)\n\nprint(\"  \" + \"-\"*65)\navg_row = f\"  {'AVERAGE':<20}\"\nfor mn in builders:\n    avg_row += f\" {np.mean(ps_accs[mn]):>7.2f}%\"\nprint(avg_row)\n\n# ============================================================\n# DL ENSEMBLE COMBINATIONS\n# ============================================================\nprint(\"\\n\" + \"=\"*60)\nprint(\"  рҹ“Ҡ DL ENSEMBLE COMBINATIONS (vs global y_actual)\")\nprint(\"=\"*60)\n\ndl_ensembles = {}\n\n# Individual\nfor mn in builders:\n    dl_ensembles[mn] = dl_full[mn].copy()\n\n# 2-model\nprint(\"\\n  2-Model:\")\nfor c in itertools.combinations(list(builders.keys()), 2):\n    name = '+'.join(c)\n    pred = np.mean([dl_full[m] for m in c], axis=0)\n    dl_ensembles[name] = pred\n    acc  = threshold_accuracy(y_actual, pred, 5)\n    print(f\"    {name:<20} Acc@5%: {acc:.2f}%\")\n\n# 3-model\nprint(\"\\n  3-Model:\")\nfor c in itertools.combinations(list(builders.keys()), 3):\n    name = '+'.join(c)\n    pred = np.mean([dl_full[m] for m in c], axis=0)\n    dl_ensembles[name] = pred\n    acc  = threshold_accuracy(y_actual, pred, 5)\n    print(f\"    {name:<25} Acc@5%: {acc:.2f}%\")\n\n# 4-model\npred_4 = np.mean([dl_full[m] for m in builders], axis=0)\ndl_ensembles['All4'] = pred_4\nacc_4 = threshold_accuracy(y_actual, pred_4, 5)\nprint(f\"\\n  4-Model (All):           Acc@5%: {acc_4:.2f}%\")\n\n# Accuracy-weighted\nindiv_accs = {mn: threshold_accuracy(y_actual, dl_full[mn], 5)\n              for mn in builders}\ntotal_w    = sum(indiv_accs.values())\nif total_w > 0:\n    w_pred = sum((indiv_accs[mn]/total_w) * dl_full[mn]\n                 for mn in builders)\nelse:\n    w_pred = pred_4\ndl_ensembles['AccWeighted'] = w_pred\nacc_w = threshold_accuracy(y_actual, w_pred, 5)\nprint(f\"  AccWeighted:             Acc@5%: {acc_w:.2f}%\")\n\n# Best DL ensemble\nbest_dl_ens  = max(dl_ensembles,\n    key=lambda n: threshold_accuracy(y_actual,\n                      dl_ensembles[n], 5))\nbest_dl_acc  = threshold_accuracy(y_actual,\n                   dl_ensembles[best_dl_ens], 5)\nbest_dl_pred = dl_ensembles[best_dl_ens]\nprint(f\"\\n  рҹҸҶ Best DL Ensemble: {best_dl_ens} вҶ’ {best_dl_acc:.2f}%\")\n\n# ============================================================\n# ML + DL COMBINED\n# ================